{
  "name": "tracev2",
  "private": true,
  "license": "FSL-1.1-ALv2",
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @trace/web dev",
    "dev:server": "pnpm --filter @trace/server dev",
    "dev:desktop": "pnpm --filter @trace/desktop dev",
    "dev:local": "node ./scripts/dev-local.mjs",
    "dev:web:prod": "VITE_API_URL=https://gettrace.org pnpm --filter @trace/web dev",
    "dev:desktop:prod": "TRACE_SERVER_URL=https://gettrace.org TRACE_WEB_URL=http://localhost:3000 pnpm --filter @trace/desktop dev",
    "dev:desktop:prod-web": "TRACE_SERVER_URL=https://gettrace.org TRACE_WEB_URL=https://gettrace.org pnpm --filter @trace/desktop dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:unit:coverage",
    "test:server": "pnpm --filter @trace/server test:unit",
    "test:server:coverage": "pnpm --filter @trace/server test:unit:coverage",
    "lint:eslint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:shared": "pnpm --filter @trace/shared build",
    "gql:codegen": "pnpm --filter @trace/gql codegen",
    "db:migrate": "pnpm --filter @trace/server exec prisma migrate dev",
    "db:generate": "pnpm --filter @trace/server exec prisma generate",
    "codegen": "pnpm db:generate && node packages/gql/scripts/codegen.cjs && pnpm --filter @trace/gql build",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper node_modules/node-pty/prebuilds/linux-*/spawn-helper 2>/dev/null || true"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "overrides": {
      "graphql": "^16.10.0",
      "@types/react": "~19.1.0",
      "picomatch": "4.0.4",
      "micromatch>picomatch": "4.0.4",
      "markdown-it@<12.3.2": ">=12.3.2",
      "electron@<35.7.5": ">=35.7.5",
      "tmp@<=0.2.3": ">=0.2.4",
      "tar@<7.5.7": ">=7.5.7",
      "tar@<=7.5.2": ">=7.5.3",
      "tar@<7.5.8": ">=7.5.8",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "@tootallnate/once@<3.0.1": ">=3.0.1",
      "tar@<=7.5.9": ">=7.5.10",
      "tar@<=7.5.10": ">=7.5.11",
      "tar@<=7.5.3": ">=7.5.4",
      "effect@<3.20.0": ">=3.20.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "@apollo/server@<5.5.0": ">=5.5.0",
      "path-to-regexp@<0.1.13": ">=0.1.13",
      "dompurify@<3.3.2": ">=3.3.2",
      "brace-expansion@<1.1.13": "1.1.14",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "dompurify@>=3.1.3 <=3.3.1": ">=3.3.2",
      "serialize-javascript@<7.0.5": ">=7.0.5",
      "lodash-es@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "dompurify@<=3.3.1": ">=3.3.2",
      "electron@<38.8.6": ">=38.8.6",
      "electron@<39.8.1": ">=39.8.1",
      "defu@<=6.1.4": ">=6.1.5",
      "electron@>=33.0.0-alpha.1 <39.8.5": ">=39.8.5",
      "vite@<=6.4.1": ">=6.4.2",
      "vite@>=6.0.0 <=6.4.1": ">=6.4.2",
      "hono@<4.12.12": ">=4.12.12",
      "electron@<39.8.5": ">=39.8.5",
      "hono@>=4.0.0 <=4.12.11": ">=4.12.12",
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "dompurify@<=3.3.3": ">=3.4.0",
      "hono@<4.12.14": ">=4.12.14",
      "sanitize-html@>=2.17.2 <2.17.3": ">=2.17.3",
      "dompurify@<3.4.0": ">=3.4.0",
      "dompurify@>=1.0.10 <3.4.0": ">=3.4.0",
      "dompurify@>=3.0.1 <3.4.0": ">=3.4.0",
      "fast-xml-parser@<5.7.0": ">=5.7.0",
      "uuid@<14.0.0": ">=14.0.0",
      "postcss@<8.5.10": ">=8.5.10",
      "@anthropic-ai/sdk@>=0.79.0 <0.81.0": ">=0.81.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "electron",
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ],
    "patchedDependencies": {}
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0"
  }
}
