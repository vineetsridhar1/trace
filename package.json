{
  "name": "tracev2",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev & pnpm dev:agent & wait",
    "dev:web": "pnpm --filter @trace/web dev",
    "dev:server": "pnpm --filter @trace/server dev",
    "dev:agent": "pnpm --filter @trace/server dev:agent",
    "dev:desktop": "pnpm --filter @trace/desktop dev",
    "dev:local": "node ./scripts/dev-local.mjs",
    "dev:web:prod": "VITE_API_URL=https://gettrace.org pnpm --filter @trace/web dev",
    "dev:desktop:prod": "TRACE_SERVER_URL=https://gettrace.org TRACE_WEB_URL=http://localhost:3000 pnpm --filter @trace/desktop dev",
    "dev:desktop:prod-web": "TRACE_SERVER_URL=https://gettrace.org TRACE_WEB_URL=https://gettrace.org pnpm --filter @trace/desktop dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:unit:coverage",
    "test:server": "pnpm --filter @trace/server test:unit",
    "test:server:coverage": "pnpm --filter @trace/server test:unit:coverage",
    "lint:eslint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:shared": "pnpm --filter @trace/shared build",
    "gql:codegen": "pnpm --filter @trace/gql codegen",
    "db:migrate": "pnpm --filter @trace/server exec prisma migrate dev",
    "db:generate": "pnpm --filter @trace/server exec prisma generate",
    "codegen": "pnpm db:generate && node packages/gql/scripts/codegen.cjs && pnpm --filter @trace/gql build",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper node_modules/node-pty/prebuilds/linux-*/spawn-helper 2>/dev/null || true"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "overrides": {
      "graphql": "^16.10.0",
      "@types/react": "~19.1.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "electron",
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ],
    "patchedDependencies": {}
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0"
  }
}
