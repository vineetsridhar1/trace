{
  "name": "@trace/desktop",
  "private": true,
  "version": "0.0.4",
  "productName": "Trace",
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/vineetsridhar1/trace.git"
  },
  "scripts": {
    "dev": "pnpm --filter @trace/shared build && tsc -b && electron-forge start",
    "build": "pnpm --filter @trace/shared build && tsc -b",
    "package": "node scripts/forge-release.mjs package",
    "make": "node scripts/forge-release.mjs make",
    "publish:mac": "node scripts/forge-release.mjs publish",
    "lint": "tsc -b",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@trace/shared": "workspace:*",
    "node-pty": "^1.1.0",
    "update-electron-app": "^3.1.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@types/node": "^24.5.2",
    "@types/ws": "^8.5.13",
    "electron": "41.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "config": {
    "forge": "./forge.config.mjs"
  }
}
