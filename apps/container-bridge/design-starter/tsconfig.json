{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@design-system": ["./design-system/components/index.ts"],
      "@design-system/*": ["./design-system/components/*"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client"]
  },
  "include": ["src", "server", "scripts", "server.ts", "vite.config.ts", "tailwind.config.ts"],
  "exclude": ["node_modules"]
}
