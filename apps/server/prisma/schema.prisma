generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enable pgvector extension for semantic search over memories and summaries.
// Run `CREATE EXTENSION IF NOT EXISTS vector;` on the database before migrating.
// The actual vector columns use Unsupported("vector(1536)") on the models.

enum UserRole {
  admin
  member
  observer
}

enum ChannelType {
  text
  coding
}

enum AgentStatus {
  not_started
  active
  done
  failed
  stopped
}

enum SessionStatus {
  in_progress
  needs_input
  in_review
  merged
}

enum TicketStatus {
  backlog
  todo
  in_progress
  in_review
  done
  cancelled
}

enum Priority {
  urgent
  high
  medium
  low
}

enum HostingMode {
  cloud
  local
}

enum BridgeAccessScopeType {
  all_sessions
  session_group
}

enum BridgeAccessRequestStatus {
  pending
  approved
  denied
}

enum CodingTool {
  claude_code
  codex
  custom
}

enum ChatType {
  dm
  group
}

enum ScopeType {
  channel
  chat
  session
  ticket
  system
}

enum ActorType {
  user
  agent
  system
}

enum InboxItemType {
  plan
  question
  agent_escalation
  agent_suggestion
  ticket_suggestion
  link_suggestion
  session_suggestion
  field_change_suggestion
  comment_suggestion
  message_suggestion
}

enum InboxItemStatus {
  active
  resolved
  dismissed
  expired
}

enum ApiTokenProvider {
  anthropic
  openai
  github
  ssh_key
}

enum ParticipantScope {
  channel
  chat
  session
  ticket
  thread
  system
}

enum CloudMachineStatus {
  creating
  started
  stopped
  destroyed
}

enum OrgAgentStatus {
  enabled
  disabled
}

enum AutonomyMode {
  observe
  suggest
  act
}

enum ModelTier {
  tier2
  tier3
}

enum MemoryKind {
  fact
  preference
  decision
  pattern
  relationship
}

enum ExecutionDisposition {
  ignore
  suggest
  act
  summarize
  escalate
}

enum ExecutionStatus {
  succeeded
  suggested
  blocked
  dropped
  failed
}

enum SummaryType {
  rolling
  milestone
}

enum AiConversationVisibility {
  PRIVATE
  ORG
}

enum TurnRole {
  USER
  ASSISTANT
}

enum EventType {
  message_sent
  message_edited
  message_deleted
  bridge_access_requested
  bridge_access_request_resolved
  bridge_access_revoked
  session_started
  session_paused
  session_resumed
  session_terminated
  session_deleted
  session_output
  ticket_created
  ticket_updated
  ticket_commented
  entity_linked
  repo_created
  repo_updated
  channel_created
  channel_updated
  channel_member_added
  channel_member_removed
  channel_group_created
  channel_group_updated
  channel_deleted
  channel_group_deleted
  member_joined
  member_left
  inbox_item_created
  inbox_item_resolved
  session_pr_opened
  session_pr_merged
  session_pr_closed
  session_group_archived
  ticket_assigned
  ticket_unassigned
  ticket_linked
  ticket_unlinked
  chat_created
  chat_member_added
  chat_member_removed
  chat_renamed
  queued_message_added
  queued_message_removed
  queued_messages_cleared
  queued_messages_drained
}

model Organization {
  id       String   @id @default(uuid())
  name     String
  settings Json     @default("{}")

  orgMembers OrgMember[]
  repos    Repo[]
  projects Project[]
  bridgeRuntimes BridgeRuntime[]
  channelGroups ChannelGroup[]
  channels Channel[]
  sessionGroups SessionGroup[]
  sessions Session[]
  tickets  Ticket[]
  events        Event[]
  inboxItems    InboxItem[]
  cloudMachines CloudMachine[]
  agentIdentity    AgentIdentity?
  executionLogs    AgentExecutionLog[]
  processedEvents  ProcessedAgentEvent[]
  costTrackers     AgentCostTracker[]
  entitySummaries  EntitySummary[]
  derivedMemories  DerivedMemory[]
  memoryExtractionCursors MemoryExtractionCursor[]
  aiConversations  AiConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrgMember {
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           UserRole     @default(member)
  joinedAt       DateTime     @default(now())

  @@id([userId, organizationId])
  @@index([organizationId])
}

model AgentIdentity {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String       @default("Trace AI")
  status         OrgAgentStatus  @default(enabled)
  autonomyMode   AutonomyMode @default(observe)
  soulFile       String       @default("")
  dailyLimitCents Int         @default(1000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentExecutionLog {
  id                    String               @id @default(uuid())
  organizationId        String
  organization          Organization         @relation(fields: [organizationId], references: [id])
  triggerEventId        String
  batchSize             Int                  @default(1)
  agentId               String
  modelTier             ModelTier
  model                 String
  promoted              Boolean              @default(false)
  promotionReason       String?
  inputTokens           Int
  outputTokens          Int
  estimatedCostCents    Float
  contextTokenAllocation Json                @default("{}")
  disposition           ExecutionDisposition
  confidence            Float
  plannedActions        Json                 @default("[]")
  policyDecision        Json                 @default("{}")
  finalActions          Json                 @default("[]")
  status                ExecutionStatus
  inboxItemId           String?
  latencyMs             Int
  replayPacket          Json?
  promptVersions        Json?

  llmCalls  AgentLlmCall[]

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([triggerEventId])
  @@index([organizationId, agentId, status])
}

model AgentLlmCall {
  id                 String             @id @default(uuid())
  executionLogId     String
  executionLog       AgentExecutionLog  @relation(fields: [executionLogId], references: [id], onDelete: Cascade)
  turnNumber         Int
  model              String
  provider           String
  systemPrompt       String?            @db.Text
  messages           Json
  tools              Json               @default("[]")
  maxTokens          Int?
  temperature        Float?
  responseContent    Json
  stopReason         String
  inputTokens        Int
  outputTokens       Int
  estimatedCostCents Float
  latencyMs          Int
  createdAt          DateTime           @default(now())

  @@index([executionLogId, turnNumber])
  @@index([createdAt])
}

model ProcessedAgentEvent {
  consumerName   String
  eventId        String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  resultHash     String?

  processedAt DateTime @default(now())

  @@id([consumerName, eventId])
  @@index([organizationId, processedAt])
}

model AgentCostTracker {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  date           String       // YYYY-MM-DD
  totalCostCents Float        @default(0)
  tier2Calls     Int          @default(0)
  tier2CostCents Float        @default(0)
  tier3Calls     Int          @default(0)
  tier3CostCents Float        @default(0)
  summaryCalls     Int        @default(0)
  summaryCostCents Float      @default(0)

  updatedAt DateTime @updatedAt

  @@unique([organizationId, date])
}

model EntitySummary {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  entityType     String       // channel, chat, ticket, session, project, repo
  entityId       String
  summaryType    SummaryType  @default(rolling)
  content        String       @default("")
  structuredData Json         @default("{}")
  startEventId   String?
  endEventId     String?
  eventCount     Int          @default(0)

  /// pgvector embedding for semantic search (Phase 4). Nullable — populated by embedding worker.
  embedding      Unsupported("vector(1536)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, entityType, entityId, summaryType])
  @@index([organizationId, entityType, entityId])
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String
  avatarUrl      String?
  githubId       Int?         @unique

  orgMemberships    OrgMember[]
  ownedBridgeRuntimes BridgeRuntime[] @relation("BridgeRuntimeOwner")
  bridgeAccessGrants BridgeAccessGrant[] @relation("BridgeAccessGrantGrantee")
  grantedBridgeAccessGrants BridgeAccessGrant[] @relation("BridgeAccessGrantGrantedBy")
  requestedBridgeAccess BridgeAccessRequest[] @relation("BridgeAccessRequestRequester")
  ownedBridgeAccessRequests BridgeAccessRequest[] @relation("BridgeAccessRequestOwner")
  resolvedBridgeAccessRequests BridgeAccessRequest[] @relation("BridgeAccessRequestResolver")
  createdSessions   Session[]        @relation("SessionCreator")
  createdTickets    Ticket[]         @relation("TicketCreator")
  ticketAssignments TicketAssignee[] @relation("TicketAssignees")
  createdChats      Chat[]           @relation("ChatCreator")
  chatMemberships      ChatMember[]
  channelMemberships   ChannelMember[]
  participants         Participant[]
  apiTokens         ApiToken[]
  cloudMachines     CloudMachine[]
  aiConversations   AiConversation[] @relation("AiConversationCreator")
  aiBranches        AiBranch[]       @relation("AiBranchCreator")
  queuedMessages    QueuedMessage[]  @relation("QueuedMessageCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Repo {
  id             String       @id @default(uuid())
  name           String
  remoteUrl      String
  defaultBranch  String       @default("main")
  setupConfig    Json         @default("{}")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  projects Project[]
  sessions Session[]
  sessionGroups SessionGroup[]
  channels Channel[]
  gitCheckpoints GitCheckpoint[]

  webhookId     String?
  webhookSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, remoteUrl])
}

model Project {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])
  aiMode         AutonomyMode?
  soulFile       String       @default("")

  channels       ChannelProject[]
  sessions       SessionProject[]
  tickets        TicketProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChannelGroup {
  id             String       @id @default(uuid())
  name           String
  position       Int          @default(0)
  isCollapsed    Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  channels Channel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, position])
}

model Channel {
  id             String       @id @default(uuid())
  name           String
  type           ChannelType  @default(coding)
  position       Int          @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  groupId        String?
  group          ChannelGroup? @relation(fields: [groupId], references: [id])
  repoId         String?
  repo           Repo?         @relation(fields: [repoId], references: [id])
  baseBranch     String?
  aiMode         AutonomyMode?
  setupScript    String?
  runScripts     Json?          @default("[]")

  projects ChannelProject[]
  sessionGroups SessionGroup[]
  sessions Session[]
  tickets  Ticket[]
  members  ChannelMember[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, position])
}

model ChannelProject {
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([channelId, projectId])
}

model ChannelMember {
  channelId       String
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt        DateTime @default(now())
  leftAt          DateTime?

  @@id([channelId, userId])
  @@index([userId])
  @@index([channelId, leftAt])
}

model SessionGroup {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])
  slug           String?
  branch         String?
  workdir        String?
  connection     Json?
  prUrl          String?
  worktreeDeleted Boolean     @default(false)
  archivedAt      DateTime?
  setupStatus     String      @default("idle")
  setupError      String?

  sessions Session[]
  gitCheckpoints GitCheckpoint[]
  bridgeAccessGrants BridgeAccessGrant[]
  bridgeAccessRequests BridgeAccessRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, updatedAt])
  @@index([channelId, updatedAt])
  @@index([repoId, branch, updatedAt])
}

model Session {
  id             String       @id @default(uuid())
  name           String
  agentStatus    AgentStatus   @default(not_started)
  sessionStatus  SessionStatus @default(in_progress)
  tool           CodingTool
  model          String?
  toolChangedAt      DateTime?
  lastUserMessageAt  DateTime?
  lastMessageAt      DateTime?
  hosting        HostingMode
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("SessionCreator", fields: [createdById], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])
  branch         String?
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])
  sessionGroupId String?
  sessionGroup   SessionGroup? @relation(fields: [sessionGroupId], references: [id])
  workdir         String?
  toolSessionId   String?
  pendingRun      Json?
  endpoints       Json?
  connection      Json?
  prUrl           String?
  worktreeDeleted Boolean      @default(false)
  readOnlyWorkspace Boolean    @default(false)

  projects        SessionProject[]
  queuedMessages  QueuedMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionGroupId, updatedAt])
  @@index([organizationId, agentStatus])
  @@index([channelId, updatedAt])
}

model QueuedMessage {
  id              String   @id @default(uuid())
  sessionId       String
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  text            String
  interactionMode String?
  position        Int
  createdById     String
  createdBy       User     @relation("QueuedMessageCreator", fields: [createdById], references: [id])
  organizationId  String
  createdAt       DateTime @default(now())

  @@index([sessionId, position])
}

model SessionProject {
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([sessionId, projectId])
}

model Ticket {
  id             String       @id @default(uuid())
  title          String
  description    String       @default("")
  status         TicketStatus @default(backlog)
  priority       Priority     @default(medium)
  labels         String[]     @default([])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("TicketCreator", fields: [createdById], references: [id])
  originEventId  String?
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])
  aiMode         AutonomyMode?

  projects  TicketProject[]
  assignees TicketAssignee[]
  links     TicketLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status, priority])
}

model TicketProject {
  ticketId  String
  ticket    Ticket  @relation(fields: [ticketId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([ticketId, projectId])
}

model TicketAssignee {
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("TicketAssignees", fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([ticketId, userId])
}

model TicketLink {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  @@unique([ticketId, entityType, entityId])
  @@index([entityType, entityId])
}

model ApiToken {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  provider       ApiTokenProvider
  encryptedToken String
  iv             String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
}

model Event {
  id             String       @id @default(uuid())
  scopeType      ScopeType
  scopeId        String
  eventType      EventType
  payload        Json
  actorType      ActorType
  actorId        String
  parentId       String?
  metadata       Json?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  timestamp DateTime @default(now())
  gitCheckpoints GitCheckpoint[] @relation("GitCheckpointPromptEvent")

  @@index([organizationId, scopeType, scopeId])
  @@index([organizationId, eventType])
  @@index([organizationId, timestamp])
  @@index([parentId])
}

model MemoryExtractionCursor {
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id])
  scopeType          ScopeType
  scopeId            String
  lastEventId        String
  lastEventTimestamp DateTime
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@id([organizationId, scopeType, scopeId])
  @@index([organizationId, lastEventTimestamp])
}

model GitCheckpoint {
  id             String   @id @default(uuid())
  sessionId      String
  sessionGroupId String
  repoId         String
  promptEventId  String
  commitSha      String
  parentShas     String[]
  treeSha        String
  subject        String
  author         String
  committedAt    DateTime
  filesChanged   Int
  createdAt      DateTime @default(now())

  sessionGroup SessionGroup @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  repo         Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  promptEvent  Event @relation("GitCheckpointPromptEvent", fields: [promptEventId], references: [id], onDelete: Restrict)

  @@unique([sessionGroupId, commitSha])
  @@index([sessionId, committedAt])
  @@index([sessionGroupId, committedAt])
  @@index([repoId, committedAt])
  @@index([promptEventId])
}

model CloudMachine {
  id                String             @id @default(uuid())
  provider          String             // "fly", "aws", etc.
  providerMachineId String
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id])
  status            CloudMachineStatus @default(creating)
  bridgeToken       String             @unique
  runtimeInstanceId String             @unique
  providerMetadata  Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([userId, organizationId])
  @@index([status])
}

model BridgeRuntime {
  id             String       @id @default(uuid())
  instanceId     String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerUserId    String
  ownerUser      User         @relation("BridgeRuntimeOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  label          String
  hostingMode    HostingMode
  lastSeenAt     DateTime?
  connectedAt    DateTime?
  disconnectedAt DateTime?
  metadata       Json?

  accessGrants   BridgeAccessGrant[]
  accessRequests BridgeAccessRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, ownerUserId])
  @@index([organizationId, connectedAt])
}

model BridgeAccessGrant {
  id               String                @id @default(uuid())
  bridgeRuntimeId  String
  bridgeRuntime    BridgeRuntime         @relation(fields: [bridgeRuntimeId], references: [id], onDelete: Cascade)
  granteeUserId    String
  granteeUser      User                  @relation("BridgeAccessGrantGrantee", fields: [granteeUserId], references: [id], onDelete: Cascade)
  grantedByUserId  String
  grantedByUser    User                  @relation("BridgeAccessGrantGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Cascade)
  scopeType        BridgeAccessScopeType
  sessionGroupId   String?
  sessionGroup     SessionGroup?         @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  expiresAt        DateTime?
  revokedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bridgeRuntimeId, granteeUserId, revokedAt])
  @@index([granteeUserId, revokedAt, expiresAt])
  @@index([sessionGroupId, revokedAt])
}

model BridgeAccessRequest {
  id                 String                    @id @default(uuid())
  bridgeRuntimeId    String
  bridgeRuntime      BridgeRuntime             @relation(fields: [bridgeRuntimeId], references: [id], onDelete: Cascade)
  requesterUserId    String
  requesterUser      User                      @relation("BridgeAccessRequestRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  ownerUserId        String
  ownerUser          User                      @relation("BridgeAccessRequestOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  scopeType          BridgeAccessScopeType
  sessionGroupId     String?
  sessionGroup       SessionGroup?             @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  requestedExpiresAt DateTime?
  status             BridgeAccessRequestStatus @default(pending)
  resolvedAt         DateTime?
  resolvedByUserId   String?
  resolvedByUser     User?                     @relation("BridgeAccessRequestResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bridgeRuntimeId, requesterUserId, status])
  @@index([ownerUserId, status, createdAt])
  @@index([sessionGroupId, status])
}

model InboxItem {
  id             String          @id @default(uuid())
  itemType       InboxItemType
  status         InboxItemStatus @default(active)
  title          String
  summary        String?
  payload        Json            @default("{}")
  userId         String
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  sourceType     String
  sourceId       String
  createdAt      DateTime        @default(now())
  resolvedAt     DateTime?
  updatedAt      DateTime        @updatedAt

  @@index([userId, status])
  @@index([organizationId, userId])
  @@index([sourceType, sourceId])
}

model Chat {
  id             String       @id @default(uuid())
  type           ChatType
  name           String?
  dmKey          String?      @unique
  createdById    String
  createdBy      User         @relation("ChatCreator", fields: [createdById], references: [id])
  aiMode         AutonomyMode?

  members ChatMember[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id              String       @id @default(uuid())
  chatId          String?
  chat            Chat?        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  channelId       String?
  channel         Channel?     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  actorType       ActorType
  actorId         String
  text            String
  html            String?
  mentions        Json?
  parentMessageId String?
  parentMessage   Message?     @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies         Message[]    @relation("MessageThread")
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([chatId, createdAt])
  @@index([channelId, createdAt])
  @@index([channelId, deletedAt])
  @@index([parentMessageId, createdAt])
}

model ChatMember {
  chatId          String
  chat            Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt        DateTime @default(now())
  leftAt          DateTime?

  @@id([chatId, userId])
  @@index([userId])
}

model Participant {
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopeType    ParticipantScope
  scopeId      String
  subscribedAt DateTime         @default(now())
  mutedAt        DateTime?

  @@id([userId, scopeType, scopeId])
  @@index([scopeType, scopeId])
}

model AiConversation {
  id             String                   @id @default(uuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User                     @relation("AiConversationCreator", fields: [createdById], references: [id])
  title          String?
  visibility     AiConversationVisibility @default(PRIVATE)
  rootBranchId   String?

  branches AiBranch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, createdById])
  @@index([organizationId, updatedAt])
}

model AiBranch {
  id             String         @id @default(uuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parentBranchId String?
  parentBranch   AiBranch?      @relation("AiBranchTree", fields: [parentBranchId], references: [id])
  childBranches  AiBranch[]     @relation("AiBranchTree")
  forkTurnId     String?
  forkTurn       AiTurn?        @relation("ForkTurn", fields: [forkTurnId], references: [id])
  label          String?
  createdById    String
  createdBy      User           @relation("AiBranchCreator", fields: [createdById], references: [id])

  turns AiTurn[]

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([parentBranchId])
}

model AiTurn {
  id           String   @id @default(uuid())
  branchId     String
  branch       AiBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  role         TurnRole
  content      String
  parentTurnId String?    @unique
  parentTurn   AiTurn?    @relation("AiTurnChain", fields: [parentTurnId], references: [id])
  childTurn    AiTurn?    @relation("AiTurnChain")

  forkedBranches AiBranch[] @relation("ForkTurn")

  createdAt DateTime @default(now())

  @@index([branchId, createdAt])
  @@index([parentTurnId])
}

model DerivedMemory {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  // What kind of memory
  kind            MemoryKind

  // What it's about
  subjectType     String       // user, project, repo, team, channel
  subjectId       String

  // Where it was extracted from (provenance)
  sourceScopeType ScopeType
  sourceScopeId   String
  sourceIsDm      Boolean      @default(false)
  startEventId    String
  endEventId      String
  sourceType      String       @default("auto") // "auto" | "summary" | "manual"

  // The actual content
  content         String
  structuredData  Json         @default("{}")

  // Confidence and lifecycle
  confidence      Float        @default(0.7)
  validFrom       DateTime     @default(now())
  validTo         DateTime?
  supersededBy    String?

  /// pgvector embedding for semantic search (Phase 4). Nullable — populated by embedding worker.
  embedding       Unsupported("vector(1536)")?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId, subjectType, subjectId])
  @@index([organizationId, sourceScopeType, sourceScopeId])
  @@index([organizationId, kind])
  @@index([organizationId, validTo])
  @@index([startEventId])
  @@index([endEventId])
}
