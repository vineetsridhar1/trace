generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  member
  observer
}

enum ChannelType {
  text
  coding
}

enum AgentStatus {
  not_started
  active
  done
  failed
  stopped
}

enum SessionStatus {
  in_progress
  needs_input
  in_review
  merged
}

enum TicketStatus {
  backlog
  todo
  in_progress
  in_review
  done
  cancelled
}

enum Priority {
  urgent
  high
  medium
  low
}

enum HostingMode {
  cloud
  local
}

enum CodingTool {
  claude_code
  codex
  custom
}

enum ChatType {
  dm
  group
}

enum ScopeType {
  channel
  chat
  session
  ticket
  system
}

enum ActorType {
  user
  agent
  system
}

enum InboxItemType {
  plan
  question
  agent_escalation
  agent_suggestion
  ticket_suggestion
  link_suggestion
  session_suggestion
  field_change_suggestion
  comment_suggestion
  message_suggestion
}

enum InboxItemStatus {
  active
  resolved
  dismissed
  expired
}

enum ApiTokenProvider {
  anthropic
  openai
  github
  ssh_key
}

enum ParticipantScope {
  channel
  chat
  session
  ticket
  thread
  system
}

enum CloudMachineStatus {
  creating
  started
  stopped
  destroyed
}

enum OrgAgentStatus {
  enabled
  disabled
}

enum AutonomyMode {
  observe
  suggest
  act
}

enum ModelTier {
  tier2
  tier3
}

enum ExecutionDisposition {
  ignore
  suggest
  act
  summarize
  escalate
}

enum ExecutionStatus {
  succeeded
  suggested
  blocked
  dropped
  failed
}

enum SummaryType {
  rolling
  milestone
}

enum AiConversationVisibility {
  PRIVATE
  ORG
}

enum TurnRole {
  USER
  ASSISTANT
}

enum EventType {
  message_sent
  message_edited
  message_deleted
  session_started
  session_paused
  session_resumed
  session_terminated
  session_deleted
  session_output
  ticket_created
  ticket_updated
  ticket_commented
  entity_linked
  repo_created
  repo_updated
  channel_created
  channel_updated
  channel_member_added
  channel_member_removed
  channel_group_created
  channel_group_updated
  channel_group_deleted
  member_joined
  member_left
  inbox_item_created
  inbox_item_resolved
  session_pr_opened
  session_pr_merged
  session_pr_closed
  ticket_assigned
  ticket_unassigned
  ticket_linked
  ticket_unlinked
  chat_created
  chat_member_added
  chat_member_removed
  chat_renamed
}

model Organization {
  id       String   @id @default(uuid())
  name     String
  settings Json     @default("{}")

  orgMembers OrgMember[]
  repos    Repo[]
  projects Project[]
  channelGroups ChannelGroup[]
  channels Channel[]
  sessionGroups SessionGroup[]
  sessions Session[]
  tickets  Ticket[]
  events        Event[]
  inboxItems    InboxItem[]
  cloudMachines CloudMachine[]
  agentIdentity    AgentIdentity?
  executionLogs    AgentExecutionLog[]
  processedEvents  ProcessedAgentEvent[]
  costTrackers     AgentCostTracker[]
  entitySummaries  EntitySummary[]
  aiConversations  AiConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrgMember {
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           UserRole     @default(member)
  joinedAt       DateTime     @default(now())

  @@id([userId, organizationId])
  @@index([organizationId])
}

model AgentIdentity {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String       @default("Trace AI")
  status         OrgAgentStatus  @default(enabled)
  autonomyMode   AutonomyMode @default(observe)
  soulFile       String       @default("")
  dailyLimitCents Int         @default(1000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentExecutionLog {
  id                    String               @id @default(uuid())
  organizationId        String
  organization          Organization         @relation(fields: [organizationId], references: [id])
  triggerEventId        String
  batchSize             Int                  @default(1)
  agentId               String
  modelTier             ModelTier
  model                 String
  promoted              Boolean              @default(false)
  promotionReason       String?
  inputTokens           Int
  outputTokens          Int
  estimatedCostCents    Float
  contextTokenAllocation Json                @default("{}")
  disposition           ExecutionDisposition
  confidence            Float
  plannedActions        Json                 @default("[]")
  policyDecision        Json                 @default("{}")
  finalActions          Json                 @default("[]")
  status                ExecutionStatus
  inboxItemId           String?
  latencyMs             Int

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([triggerEventId])
  @@index([organizationId, agentId, status])
}

model ProcessedAgentEvent {
  consumerName   String
  eventId        String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  resultHash     String?

  processedAt DateTime @default(now())

  @@id([consumerName, eventId])
  @@index([organizationId, processedAt])
}

model AgentCostTracker {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  date           String       // YYYY-MM-DD
  totalCostCents Float        @default(0)
  tier2Calls     Int          @default(0)
  tier2CostCents Float        @default(0)
  tier3Calls     Int          @default(0)
  tier3CostCents Float        @default(0)
  summaryCalls     Int        @default(0)
  summaryCostCents Float      @default(0)

  updatedAt DateTime @updatedAt

  @@unique([organizationId, date])
}

model EntitySummary {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  entityType     String       // channel, chat, ticket, session, project, repo
  entityId       String
  summaryType    SummaryType  @default(rolling)
  content        String       @default("")
  structuredData Json         @default("{}")
  startEventId   String?
  endEventId     String?
  eventCount     Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, entityType, entityId, summaryType])
  @@index([organizationId, entityType, entityId])
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String
  avatarUrl      String?
  githubId       Int?         @unique

  orgMemberships    OrgMember[]
  createdSessions   Session[]        @relation("SessionCreator")
  createdTickets    Ticket[]         @relation("TicketCreator")
  ticketAssignments TicketAssignee[] @relation("TicketAssignees")
  createdChats      Chat[]           @relation("ChatCreator")
  chatMemberships      ChatMember[]
  channelMemberships   ChannelMember[]
  participants         Participant[]
  apiTokens         ApiToken[]
  cloudMachines     CloudMachine[]
  aiConversations   AiConversation[] @relation("AiConversationCreator")
  branches          Branch[]         @relation("BranchCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Repo {
  id             String       @id @default(uuid())
  name           String
  remoteUrl      String
  defaultBranch  String       @default("main")
  setupConfig    Json         @default("{}")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  projects Project[]
  sessions Session[]
  sessionGroups SessionGroup[]
  channels Channel[]
  gitCheckpoints GitCheckpoint[]

  webhookId     String?
  webhookSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, remoteUrl])
}

model Project {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])

  channels       ChannelProject[]
  sessions       SessionProject[]
  tickets        TicketProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChannelGroup {
  id             String       @id @default(uuid())
  name           String
  position       Int          @default(0)
  isCollapsed    Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  channels Channel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, position])
}

model Channel {
  id             String       @id @default(uuid())
  name           String
  type           ChannelType  @default(coding)
  position       Int          @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  groupId        String?
  group          ChannelGroup? @relation(fields: [groupId], references: [id])
  repoId         String?
  repo           Repo?         @relation(fields: [repoId], references: [id])

  projects ChannelProject[]
  sessionGroups SessionGroup[]
  sessions Session[]
  tickets  Ticket[]
  members  ChannelMember[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, position])
}

model ChannelProject {
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([channelId, projectId])
}

model ChannelMember {
  channelId       String
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt        DateTime @default(now())
  leftAt          DateTime?

  @@id([channelId, userId])
  @@index([userId])
}

model SessionGroup {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])
  branch         String?
  workdir        String?
  connection     Json?
  prUrl          String?
  worktreeDeleted Boolean     @default(false)

  sessions Session[]
  gitCheckpoints GitCheckpoint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, updatedAt])
  @@index([channelId, updatedAt])
  @@index([repoId, branch, updatedAt])
}

model Session {
  id             String       @id @default(uuid())
  name           String
  agentStatus    AgentStatus   @default(not_started)
  sessionStatus  SessionStatus @default(in_progress)
  tool           CodingTool
  model          String?
  toolChangedAt  DateTime?
  hosting        HostingMode
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("SessionCreator", fields: [createdById], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])
  branch         String?
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])
  sessionGroupId String?
  sessionGroup   SessionGroup? @relation(fields: [sessionGroupId], references: [id])
  workdir         String?
  toolSessionId   String?
  pendingRun      Json?
  endpoints       Json?
  connection      Json?
  prUrl           String?
  worktreeDeleted Boolean      @default(false)

  projects SessionProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionGroupId, updatedAt])
}

model SessionProject {
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([sessionId, projectId])
}

model Ticket {
  id             String       @id @default(uuid())
  title          String
  description    String       @default("")
  status         TicketStatus @default(backlog)
  priority       Priority     @default(medium)
  labels         String[]     @default([])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("TicketCreator", fields: [createdById], references: [id])
  originEventId  String?
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])

  projects  TicketProject[]
  assignees TicketAssignee[]
  links     TicketLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketProject {
  ticketId  String
  ticket    Ticket  @relation(fields: [ticketId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([ticketId, projectId])
}

model TicketAssignee {
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("TicketAssignees", fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([ticketId, userId])
}

model TicketLink {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  @@unique([ticketId, entityType, entityId])
  @@index([entityType, entityId])
}

model ApiToken {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  provider       ApiTokenProvider
  encryptedToken String
  iv             String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
}

model Event {
  id             String       @id @default(uuid())
  scopeType      ScopeType
  scopeId        String
  eventType      EventType
  payload        Json
  actorType      ActorType
  actorId        String
  parentId       String?
  metadata       Json?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  timestamp DateTime @default(now())
  gitCheckpoints GitCheckpoint[] @relation("GitCheckpointPromptEvent")

  @@index([organizationId, scopeType, scopeId])
  @@index([organizationId, eventType])
  @@index([parentId])
}

model GitCheckpoint {
  id             String   @id @default(uuid())
  sessionId      String
  sessionGroupId String
  repoId         String
  promptEventId  String
  commitSha      String
  parentShas     String[]
  treeSha        String
  subject        String
  author         String
  committedAt    DateTime
  filesChanged   Int
  createdAt      DateTime @default(now())

  sessionGroup SessionGroup @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  repo         Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  promptEvent  Event @relation("GitCheckpointPromptEvent", fields: [promptEventId], references: [id], onDelete: Restrict)

  @@unique([sessionGroupId, commitSha])
  @@index([sessionId, committedAt])
  @@index([sessionGroupId, committedAt])
  @@index([repoId, committedAt])
  @@index([promptEventId])
}

model CloudMachine {
  id                String             @id @default(uuid())
  provider          String             // "fly", "aws", etc.
  providerMachineId String
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id])
  status            CloudMachineStatus @default(creating)
  bridgeToken       String             @unique
  runtimeInstanceId String             @unique
  providerMetadata  Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([userId, organizationId])
  @@index([status])
}

model InboxItem {
  id             String          @id @default(uuid())
  itemType       InboxItemType
  status         InboxItemStatus @default(active)
  title          String
  summary        String?
  payload        Json            @default("{}")
  userId         String
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  sourceType     String
  sourceId       String
  createdAt      DateTime        @default(now())
  resolvedAt     DateTime?
  updatedAt      DateTime        @updatedAt

  @@index([userId, status])
  @@index([organizationId, userId])
  @@index([sourceType, sourceId])
}

model Chat {
  id             String       @id @default(uuid())
  type           ChatType
  name           String?
  dmKey          String?      @unique
  createdById    String
  createdBy      User         @relation("ChatCreator", fields: [createdById], references: [id])

  members ChatMember[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id              String       @id @default(uuid())
  chatId          String?
  chat            Chat?        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  channelId       String?
  channel         Channel?     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  actorType       ActorType
  actorId         String
  text            String
  html            String?
  mentions        Json?
  parentMessageId String?
  parentMessage   Message?     @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies         Message[]    @relation("MessageThread")
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([chatId, createdAt])
  @@index([channelId, createdAt])
  @@index([parentMessageId, createdAt])
}

model ChatMember {
  chatId          String
  chat            Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt        DateTime @default(now())
  leftAt          DateTime?

  @@id([chatId, userId])
  @@index([userId])
}

model Participant {
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopeType    ParticipantScope
  scopeId      String
  subscribedAt DateTime         @default(now())
  mutedAt        DateTime?

  @@id([userId, scopeType, scopeId])
  @@index([scopeType, scopeId])
}

model AiConversation {
  id             String                   @id @default(uuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User                     @relation("AiConversationCreator", fields: [createdById], references: [id])
  title          String?
  visibility     AiConversationVisibility @default(PRIVATE)
  rootBranchId   String?

  branches Branch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, createdById])
  @@index([organizationId, updatedAt])
}

model Branch {
  id             String         @id @default(uuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parentBranchId String?
  parentBranch   Branch?        @relation("BranchTree", fields: [parentBranchId], references: [id])
  childBranches  Branch[]       @relation("BranchTree")
  forkTurnId     String?
  forkTurn       Turn?          @relation("ForkTurn", fields: [forkTurnId], references: [id])
  label          String?
  createdById    String
  createdBy      User           @relation("BranchCreator", fields: [createdById], references: [id])

  turns Turn[]

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([parentBranchId])
}

model Turn {
  id           String   @id @default(uuid())
  branchId     String
  branch       Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  role         TurnRole
  content      String
  parentTurnId String?  @unique
  parentTurn   Turn?    @relation("TurnChain", fields: [parentTurnId], references: [id])
  childTurn    Turn?    @relation("TurnChain")

  forkedBranches Branch[] @relation("ForkTurn")

  createdAt DateTime @default(now())

  @@index([branchId, createdAt])
  @@index([parentTurnId])
}
