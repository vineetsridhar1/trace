generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  member
  observer
}

enum ChannelType {
  text
  coding
}

enum ChannelVisibility {
  public
  private
}

enum AgentStatus {
  not_started
  active
  done
  failed
  stopped
}

enum SessionStatus {
  in_progress
  needs_input
  in_review
  merged
}

enum SessionGroupVisibility {
  public
  private
}

enum SessionGroupKind {
  coding
  design
  app
}

enum RepoProvider {
  github
  managed
}

enum TicketStatus {
  backlog
  todo
  in_progress
  in_review
  done
  cancelled
}

enum Priority {
  urgent
  high
  medium
  low
}

enum HostingMode {
  cloud
  local
}

enum BridgeAccessScopeType {
  all_sessions
  session_group
}

enum BridgeAccessRequestStatus {
  pending
  approved
  denied
}

enum BridgeAccessCapability {
  session
  terminal
}

enum CodingTool {
  claude_code
  codex
  custom
  pi
  antigravity
  cursor_composer
}

enum ChatType {
  dm
  group
}

enum ScopeType {
  channel
  chat
  session
  ticket
  system
}

enum ActorType {
  user
  agent
  system
}

enum InboxItemType {
  plan
  question
}

enum InboxItemStatus {
  active
  resolved
  dismissed
  expired
}

enum ApiTokenProvider {
  anthropic
  openai
  github
  ssh_key
}

enum PushPlatform {
  ios
  android
}

enum ParticipantScope {
  channel
  chat
  session
  ticket
  thread
  system
}

enum EventType {
  message_sent
  message_edited
  message_deleted
  bridge_access_requested
  bridge_access_request_resolved
  bridge_access_revoked
  bridge_access_updated
  session_started
  session_paused
  session_resumed
  session_terminated
  session_deleted
  session_output
  ticket_created
  ticket_updated
  ticket_commented
  entity_linked
  organization_created
  repo_created
  repo_updated
  channel_created
  channel_updated
  channel_member_added
  channel_member_removed
  channel_group_created
  channel_group_updated
  channel_deleted
  channel_group_deleted
  member_joined
  member_left
  inbox_item_created
  inbox_item_resolved
  session_pr_opened
  session_pr_merged
  session_pr_closed
  session_group_archived
  session_group_renamed
  ticket_assigned
  ticket_unassigned
  ticket_linked
  ticket_unlinked
  chat_created
  chat_member_added
  chat_member_removed
  chat_renamed
  queued_message_added
  queued_message_updated
  queued_message_removed
  queued_messages_reordered
  queued_messages_cleared
  queued_messages_drained
  agent_environment_created
  agent_environment_updated
  agent_environment_deleted
  session_runtime_start_requested
  session_runtime_provisioning
  session_runtime_connecting
  session_runtime_connected
  session_runtime_start_failed
  session_runtime_start_timed_out
  session_runtime_stopping
  session_runtime_stopped
  session_runtime_deprovision_failed
  session_runtime_disconnected
  session_runtime_reconnected
  session_group_visibility_updated
  application_config_updated
  session_setup_script_started
  session_setup_script_completed
  session_setup_script_failed
  session_application_process_started
  session_application_process_stopped
  session_application_process_failed
  session_application_log_appended
  session_endpoint_created
  session_endpoint_forwarding_enabled
  session_endpoint_forwarding_disabled
  session_endpoint_rotated
  session_endpoint_access_updated
  session_endpoint_traffic_capture_updated
  design_artifact_created
  design_artifact_updated
  design_comment_added
  design_export_completed
  design_artifact_promoted
}

enum SessionApplicationProcessStatus {
  stopped
  starting
  running
  stopping
  exited
  failed
}

enum SessionSetupScriptRunStatus {
  running
  completed
  failed
}

enum SessionEndpointStatus {
  disabled
  enabled
  unavailable
  revoked
}

enum SessionEndpointAccessMode {
  private
  public
}

enum EndpointTrafficCaptureMode {
  metadata
  headers
  full
}

model Organization {
  id       String   @id @default(uuid())
  name     String
  settings Json     @default("{}")

  orgMembers OrgMember[]
  pushTokens PushToken[]
  mobilePairingTokens MobilePairingToken[]
  pairedMobileDevices MobileDevice[]
  repos    Repo[]
  projects Project[]
  bridgeRuntimes BridgeRuntime[]
  channelGroups ChannelGroup[]
  channels Channel[]
  sessionGroups SessionGroup[]
  sessions Session[]
  tickets  Ticket[]
  events        Event[]
  inboxItems    InboxItem[]
  sessionSetupScriptRuns SessionSetupScriptRun[]
  sessionApplicationProcesses SessionApplicationProcess[]
  sessionEndpoints SessionEndpoint[]
  artifacts Artifact[]
  agentEnvironments AgentEnvironment[]
  orgSecrets    OrgSecret[]
  slackInstalls SlackInstall[]
  slackChannelBindings SlackChannelBinding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrgMember {
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           UserRole     @default(member)
  joinedAt       DateTime     @default(now())

  @@id([userId, organizationId])
  @@index([organizationId])
}

model AgentEnvironment {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  adapterType    String
  config         Json         @default("{}")
  enabled        Boolean      @default(true)
  isDefault      Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, adapterType])
}

model OrgSecret {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  encryptedValue String
  iv             String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String
  avatarUrl      String?
  githubId       Int?         @unique
  defaultSessionTool            CodingTool?
  defaultSessionModel           String?
  defaultSessionReasoningEffort String?
  autoArchiveMergedSessions      Boolean      @default(true)
  enableClaudeInChrome           Boolean      @default(false)

  orgMemberships    OrgMember[]
  mobilePairingTokens MobilePairingToken[] @relation("MobilePairingTokenOwner")
  mobileDevices MobileDevice[] @relation("MobileDeviceOwner")
  ownedBridgeRuntimes BridgeRuntime[] @relation("BridgeRuntimeOwner")
  bridgeAccessGrants BridgeAccessGrant[] @relation("BridgeAccessGrantGrantee")
  grantedBridgeAccessGrants BridgeAccessGrant[] @relation("BridgeAccessGrantGrantedBy")
  requestedBridgeAccess BridgeAccessRequest[] @relation("BridgeAccessRequestRequester")
  ownedBridgeAccessRequests BridgeAccessRequest[] @relation("BridgeAccessRequestOwner")
  resolvedBridgeAccessRequests BridgeAccessRequest[] @relation("BridgeAccessRequestResolver")
  createdSessions   Session[]        @relation("SessionCreator")
  ownedSessionGroups SessionGroup[]   @relation("SessionGroupOwner")
  createdTickets    Ticket[]         @relation("TicketCreator")
  ticketAssignments TicketAssignee[] @relation("TicketAssignees")
  createdChats      Chat[]           @relation("ChatCreator")
  ownedChannels     Channel[]        @relation("ChannelOwner")
  chatMemberships      ChatMember[]
  channelMemberships   ChannelMember[]
  participants         Participant[]
  apiTokens         ApiToken[]
  pushTokens        PushToken[]
  queuedMessages    QueuedMessage[]  @relation("QueuedMessageCreator")
  slackInstalls     SlackInstall[]   @relation("SlackInstallInstaller")
  slackAccounts     SlackAccount[]
  slackChannelBindings SlackChannelBinding[]
  createdArtifacts  Artifact[]       @relation("ArtifactCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Repo {
  id             String       @id @default(uuid())
  name           String
  provider       RepoProvider @default(github)
  remoteUrl      String?
  defaultBranch  String       @default("main")
  setupConfig    Json         @default("{}")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  projects Project[]
  sessions Session[]
  sessionGroups SessionGroup[]
  channels Channel[]
  gitCheckpoints GitCheckpoint[]
  sessionSetupScriptRuns SessionSetupScriptRun[]
  sessionApplicationProcesses SessionApplicationProcess[]
  sessionEndpoints SessionEndpoint[]

  webhookId     String?
  webhookSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, remoteUrl])
}

model Project {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])
  soulFile       String       @default("")

  channels       ChannelProject[]
  sessions       SessionProject[]
  tickets        TicketProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChannelGroup {
  id             String       @id @default(uuid())
  name           String
  position       Int          @default(0)
  isCollapsed    Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  channels Channel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, position])
}

model Channel {
  id             String       @id @default(uuid())
  name           String
  type           ChannelType  @default(coding)
  visibility     ChannelVisibility @default(public)
  position       Int          @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  ownerId        String?
  owner          User?        @relation("ChannelOwner", fields: [ownerId], references: [id])
  groupId        String?
  group          ChannelGroup? @relation(fields: [groupId], references: [id])
  repoId         String?
  repo           Repo?         @relation(fields: [repoId], references: [id])
  baseBranch     String?
  setupScript    String?
  runScripts     Json?          @default("[]")

  projects ChannelProject[]
  sessionGroups SessionGroup[]
  sessions Session[]
  tickets  Ticket[]
  members  ChannelMember[]
  messages Message[]
  slackBindings SlackChannelBinding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, position])
  @@index([ownerId])
}

model ChannelProject {
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([channelId, projectId])
}

model ChannelMember {
  channelId       String
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt        DateTime @default(now())
  leftAt          DateTime?

  @@id([channelId, userId])
  @@index([userId])
  @@index([channelId, leftAt])
}

model SessionGroup {
  id             String       @id @default(uuid())
  name           String
  kind           SessionGroupKind @default(coding)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  ownerUserId    String
  ownerUser      User         @relation("SessionGroupOwner", fields: [ownerUserId], references: [id])
  forkedFromSessionGroupId String?
  forkedFromSessionGroup   SessionGroup?  @relation("SessionGroupForks", fields: [forkedFromSessionGroupId], references: [id])
  forkedSessionGroups      SessionGroup[] @relation("SessionGroupForks")
  visibility     SessionGroupVisibility @default(public)
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])
  slug           String?
  branch         String?
  workdir        String?
  connection     Json?
  prUrl          String?
  prSyncObservedAt DateTime?
  prSyncError      String?
  worktreeDeleted Boolean     @default(false)
  archivedAt      DateTime?
  setupStatus     String      @default("idle")
  setupError      String?

  sessions Session[]
  gitCheckpoints GitCheckpoint[]
  bridgeAccessGrants BridgeAccessGrant[]
  bridgeAccessRequests BridgeAccessRequest[]
  setupScriptRuns SessionSetupScriptRun[]
  applicationProcesses SessionApplicationProcess[]
  endpoints SessionEndpoint[]
  artifacts Artifact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repoId, slug])
  @@index([organizationId, updatedAt])
  @@index([organizationId, visibility, ownerUserId])
  @@index([forkedFromSessionGroupId])
  @@index([channelId, updatedAt])
  @@index([repoId, branch, updatedAt])
}

model Artifact {
  id               String       @id @default(uuid())
  sessionGroupId   String
  sessionGroup     SessionGroup @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  parentArtifactId String?
  parentArtifact   Artifact?    @relation("ArtifactLineage", fields: [parentArtifactId], references: [id], onDelete: SetNull)
  childArtifacts   Artifact[]   @relation("ArtifactLineage")
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  createdById      String
  createdBy        User         @relation("ArtifactCreator", fields: [createdById], references: [id])
  promptEventId    String?
  prompt           String?
  title            String
  contentType      String
  html             String
  metadata         Json?
  publishedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, sessionGroupId, createdAt])
  @@index([parentArtifactId])
  @@index([promptEventId])
}

model Session {
  id             String       @id @default(uuid())
  name           String
  agentStatus    AgentStatus   @default(not_started)
  sessionStatus  SessionStatus @default(in_progress)
  tool           CodingTool
  model          String?
  reasoningEffort String?
  toolChangedAt      DateTime?
  lastUserMessageAt  DateTime?
  lastMessageAt      DateTime?
  hosting        HostingMode
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("SessionCreator", fields: [createdById], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])
  branch         String?
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])
  sessionGroupId String?
  sessionGroup   SessionGroup? @relation(fields: [sessionGroupId], references: [id])
  workdir         String?
  toolSessionId   String?
  pendingRun      Json?
  endpoints       Json?
  connection      Json?
  prUrl           String?
  worktreeDeleted Boolean      @default(false)
  readOnlyWorkspace Boolean    @default(false)

  inputTokens         BigInt @default(0)
  outputTokens        BigInt @default(0)
  cacheReadTokens     BigInt @default(0)
  cacheCreationTokens BigInt @default(0)
  costUsd             Float @default(0)

  projects        SessionProject[]
  queuedMessages  QueuedMessage[]
  slackThread     SlackThreadSession?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionGroupId, updatedAt])
  @@index([organizationId, agentStatus])
  @@index([channelId, updatedAt])
}

model SessionSetupScriptRun {
  id               String                      @id @default(uuid())
  organizationId   String
  organization     Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessionGroupId   String
  sessionGroup     SessionGroup                @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  repoId           String
  repo             Repo                        @relation(fields: [repoId], references: [id], onDelete: Cascade)

  scriptConfigId   String
  label            String
  command          String
  workingDirectory String
  status           SessionSetupScriptRunStatus @default(running)
  exitCode         Int?
  outputPreview    String?
  outputTruncated  Boolean                     @default(false)
  lastError        String?

  startedByUserId  String?
  startedAt        DateTime                    @default(now())
  completedAt      DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@index([organizationId, sessionGroupId])
  @@index([sessionGroupId, scriptConfigId, startedAt])
}

model SessionApplicationProcess {
  id                 String                          @id @default(uuid())
  organizationId     String
  organization       Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessionGroupId     String
  sessionGroup       SessionGroup                    @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  repoId             String
  repo               Repo                            @relation(fields: [repoId], references: [id], onDelete: Cascade)

  appConfigId        String
  processConfigId    String
  label              String
  command            String
  workingDirectory   String
  status             SessionApplicationProcessStatus @default(stopped)
  runtimeInstanceId  String?
  bridgeProcessId    String?
  exitCode           Int?
  lastError          String?

  startedByUserId    String?
  startedAt          DateTime?
  stoppedAt          DateTime?
  lastHeartbeatAt    DateTime?
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt

  logEntries         SessionApplicationLogEntry[]

  @@unique([sessionGroupId, appConfigId, processConfigId])
  @@index([organizationId, sessionGroupId])
  @@index([runtimeInstanceId])
}

model SessionApplicationLogEntry {
  id             String                    @id @default(uuid())
  organizationId String
  processId      String
  process        SessionApplicationProcess @relation(fields: [processId], references: [id], onDelete: Cascade)

  stream         String
  data           String
  sequence       Int
  timestamp      DateTime                  @default(now())

  @@index([processId, sequence])
  @@index([organizationId, timestamp])
}

model SessionEndpoint {
  id                       String                     @id @default(uuid())
  key                      String                     @unique
  organizationId           String
  organization             Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessionGroupId           String
  sessionGroup             SessionGroup               @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  repoId                   String
  repo                     Repo                       @relation(fields: [repoId], references: [id], onDelete: Cascade)

  appConfigId              String
  processConfigId          String
  portConfigId             String
  label                    String
  targetPort               Int
  protocol                 String                     @default("http")

  status                   SessionEndpointStatus      @default(disabled)
  accessMode               SessionEndpointAccessMode  @default(private)
  trafficCaptureMode       EndpointTrafficCaptureMode @default(metadata)

  currentRuntimeInstanceId String?
  enabledByUserId          String?
  enabledAt                DateTime?
  disabledAt               DateTime?
  revokedAt                DateTime?
  expiresAt                DateTime?

  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  trafficEntries           EndpointTrafficEntry[]

  @@unique([sessionGroupId, appConfigId, processConfigId, portConfigId])
  @@index([organizationId, sessionGroupId])
  @@index([status])
}

model EndpointTrafficEntry {
  id                    String          @id @default(uuid())
  organizationId        String
  endpointId            String
  endpoint              SessionEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  startedAt             DateTime        @default(now())
  completedAt           DateTime?
  durationMs            Int?

  requestMethod         String
  requestPath           String
  requestQuery          String?
  requestHeaders        Json?
  requestBodyPreview    String?
  requestBodyBytes      Int?
  requestTruncated      Boolean         @default(false)

  responseStatus        Int?
  responseHeaders       Json?
  responseBodyPreview   String?
  responseBodyBytes     Int?
  responseTruncated     Boolean         @default(false)

  error                 String?

  @@index([endpointId, startedAt])
  @@index([organizationId, startedAt])
}

model QueuedMessage {
  id              String   @id @default(uuid())
  sessionId       String
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  text            String
  imageKeys       String[] @default([])
  interactionMode String?
  position        Int
  createdById     String
  createdBy       User     @relation("QueuedMessageCreator", fields: [createdById], references: [id])
  organizationId  String
  createdAt       DateTime @default(now())

  @@index([sessionId, position])
}

model SessionProject {
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([sessionId, projectId])
}

model Ticket {
  id             String       @id @default(uuid())
  title          String
  description    String       @default("")
  status         TicketStatus @default(backlog)
  priority       Priority     @default(medium)
  labels         String[]     @default([])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("TicketCreator", fields: [createdById], references: [id])
  originEventId  String?
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])

  projects  TicketProject[]
  assignees TicketAssignee[]
  links     TicketLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status, priority])
}

model TicketProject {
  ticketId  String
  ticket    Ticket  @relation(fields: [ticketId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([ticketId, projectId])
}

model TicketAssignee {
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("TicketAssignees", fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([ticketId, userId])
}

model TicketLink {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  @@unique([ticketId, entityType, entityId])
  @@index([entityType, entityId])
}

model ApiToken {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  provider       ApiTokenProvider
  encryptedToken String
  iv             String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
}

model PushToken {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  token          String
  platform       PushPlatform

  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@unique([userId, token])
  @@index([userId, organizationId])
}

model Event {
  id             String       @id @default(uuid())
  scopeType      ScopeType
  scopeId        String
  eventType      EventType
  payload        Json
  actorType      ActorType
  actorId        String
  parentId       String?
  metadata       Json?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  timestamp DateTime @default(now())
  gitCheckpoints GitCheckpoint[] @relation("GitCheckpointPromptEvent")

  @@index([organizationId, scopeType, scopeId])
  @@index([organizationId, scopeType, scopeId, timestamp])
  @@index([organizationId, eventType])
  @@index([organizationId, timestamp])
  @@index([parentId])
}

model GitCheckpoint {
  id             String   @id @default(uuid())
  sessionId      String
  sessionGroupId String
  repoId         String
  promptEventId  String
  commitSha      String
  parentShas     String[]
  treeSha        String
  subject        String
  author         String
  committedAt    DateTime
  filesChanged   Int
  createdAt      DateTime @default(now())

  sessionGroup SessionGroup @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  repo         Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  promptEvent  Event @relation("GitCheckpointPromptEvent", fields: [promptEventId], references: [id], onDelete: Restrict)

  @@unique([sessionGroupId, commitSha])
  @@index([sessionId, committedAt])
  @@index([sessionGroupId, committedAt])
  @@index([repoId, committedAt])
  @@index([promptEventId])
}

model BridgeRuntime {
  id             String       @id @default(uuid())
  instanceId     String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerUserId    String
  ownerUser      User         @relation("BridgeRuntimeOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  label          String
  hostingMode    HostingMode
  lastSeenAt     DateTime?
  connectedAt    DateTime?
  disconnectedAt DateTime?
  metadata       Json?

  accessGrants   BridgeAccessGrant[]
  accessRequests BridgeAccessRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instanceId, organizationId])
  @@index([organizationId, ownerUserId])
  @@index([organizationId, connectedAt])
}

model MobilePairingToken {
  id             String       @id @default(uuid())
  ownerUserId    String
  ownerUser      User         @relation("MobilePairingTokenOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tokenHash      String       @unique
  expiresAt      DateTime
  usedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId, organizationId, usedAt, expiresAt])
}

model MobileDevice {
  id             String       @id @default(uuid())
  ownerUserId    String
  ownerUser      User         @relation("MobileDeviceOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  pairedOrganizationId String?
  pairedOrganization   Organization? @relation(fields: [pairedOrganizationId], references: [id], onDelete: SetNull)
  installId      String
  deviceName     String?
  platform       PushPlatform?
  appVersion     String?
  tokenHash      String       @unique
  lastSeenAt     DateTime?
  revokedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerUserId, installId])
  @@index([ownerUserId, revokedAt, lastSeenAt])
}

model BridgeAccessGrant {
  id               String                @id @default(uuid())
  bridgeRuntimeId  String
  bridgeRuntime    BridgeRuntime         @relation(fields: [bridgeRuntimeId], references: [id], onDelete: Cascade)
  granteeUserId    String
  granteeUser      User                  @relation("BridgeAccessGrantGrantee", fields: [granteeUserId], references: [id], onDelete: Cascade)
  grantedByUserId  String
  grantedByUser    User                  @relation("BridgeAccessGrantGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Cascade)
  scopeType        BridgeAccessScopeType
  sessionGroupId   String?
  sessionGroup     SessionGroup?         @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  capabilities     BridgeAccessCapability[] @default([])
  expiresAt        DateTime?
  revokedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bridgeRuntimeId, granteeUserId, revokedAt])
  @@index([granteeUserId, revokedAt, expiresAt])
  @@index([sessionGroupId, revokedAt])
}

model BridgeAccessRequest {
  id                 String                    @id @default(uuid())
  bridgeRuntimeId    String
  bridgeRuntime      BridgeRuntime             @relation(fields: [bridgeRuntimeId], references: [id], onDelete: Cascade)
  requesterUserId    String
  requesterUser      User                      @relation("BridgeAccessRequestRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  ownerUserId        String
  ownerUser          User                      @relation("BridgeAccessRequestOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  scopeType          BridgeAccessScopeType
  sessionGroupId     String?
  sessionGroup       SessionGroup?             @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  requestedCapabilities BridgeAccessCapability[] @default([])
  requestedExpiresAt DateTime?
  status             BridgeAccessRequestStatus @default(pending)
  resolvedAt         DateTime?
  resolvedByUserId   String?
  resolvedByUser     User?                     @relation("BridgeAccessRequestResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bridgeRuntimeId, requesterUserId, status])
  @@index([ownerUserId, status, createdAt])
  @@index([sessionGroupId, status])
}

model InboxItem {
  id             String          @id @default(uuid())
  itemType       InboxItemType
  status         InboxItemStatus @default(active)
  title          String
  summary        String?
  payload        Json            @default("{}")
  userId         String
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  sourceType     String
  sourceId       String
  createdAt      DateTime        @default(now())
  resolvedAt     DateTime?
  updatedAt      DateTime        @updatedAt

  @@index([userId, status])
  @@index([organizationId, userId])
  @@index([sourceType, sourceId])
}

model Chat {
  id             String       @id @default(uuid())
  type           ChatType
  name           String?
  dmKey          String?      @unique
  createdById    String
  createdBy      User         @relation("ChatCreator", fields: [createdById], references: [id])

  members ChatMember[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id              String       @id @default(uuid())
  chatId          String?
  chat            Chat?        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  channelId       String?
  channel         Channel?     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  actorType       ActorType
  actorId         String
  text            String
  html            String?
  mentions        Json?
  parentMessageId String?
  parentMessage   Message?     @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies         Message[]    @relation("MessageThread")
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([chatId, createdAt])
  @@index([channelId, createdAt])
  @@index([channelId, deletedAt])
  @@index([parentMessageId, createdAt])
}

model ChatMember {
  chatId          String
  chat            Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt        DateTime @default(now())
  leftAt          DateTime?

  @@id([chatId, userId])
  @@index([userId])
}

model Participant {
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopeType    ParticipantScope
  scopeId      String
  subscribedAt DateTime         @default(now())
  mutedAt        DateTime?

  @@id([userId, scopeType, scopeId])
  @@index([scopeType, scopeId])
}

model SlackInstall {
  id                String       @id @default(uuid())
  slackTeamId       String       @unique
  slackTeamName     String?
  botUserId         String
  encryptedBotToken String
  iv                String
  installedById     String
  installedBy       User         @relation("SlackInstallInstaller", fields: [installedById], references: [id])
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt         DateTime     @default(now())

  @@index([organizationId])
}

model SlackAccount {
  id                       String      @id @default(uuid())
  slackUserId              String
  slackTeamId              String
  userId                   String
  user                     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredTool            CodingTool?
  preferredModel           String?
  preferredReasoningEffort String?
  createdAt                DateTime    @default(now())

  @@unique([slackUserId, slackTeamId])
  @@index([userId])
}

model SlackChannelBinding {
  id              String   @id @default(uuid())
  slackTeamId     String
  slackChannelId  String
  traceChannelId  String
  organizationId  String
  boundById       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  traceChannel Channel      @relation(fields: [traceChannelId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  boundBy      User         @relation(fields: [boundById], references: [id], onDelete: Cascade)

  @@unique([slackTeamId, slackChannelId])
  @@index([traceChannelId])
  @@index([organizationId])
}

model SlackSessionDraft {
  id             String   @id @default(cuid())
  slackTeamId    String
  slackChannelId String
  slackThreadTs  String
  slackUserId    String
  organizationId String
  traceChannelId String?
  prompt         String
  fileRefs       Json     @default("[]")
  createdAt      DateTime @default(now())
  expiresAt      DateTime?

  @@index([slackTeamId, slackChannelId, slackThreadTs])
  @@index([expiresAt])
}

model SlackThreadSession {
  id             String   @id @default(uuid())
  slackTeamId    String
  slackChannelId String
  slackThreadTs  String
  sessionId      String   @unique
  session        Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  organizationId String
  createdAt      DateTime @default(now())

  @@unique([slackTeamId, slackChannelId, slackThreadTs])
}

model SlackProcessedEvent {
  id           String   @id @default(uuid())
  slackTeamId  String?
  slackEventId String   @unique
  createdAt    DateTime @default(now())

  @@index([createdAt])
}
