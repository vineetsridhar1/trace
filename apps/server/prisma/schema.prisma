generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  member
  observer
}

enum ChannelType {
  default
  announcement
  triage
  feed
}

enum SessionStatus {
  creating
  pending
  active
  paused
  needs_input
  completed
  failed
  unreachable
  merged
}

enum TicketStatus {
  backlog
  todo
  in_progress
  in_review
  done
  cancelled
}

enum Priority {
  urgent
  high
  medium
  low
}

enum HostingMode {
  cloud
  local
}

enum CodingTool {
  claude_code
  codex
  custom
}

enum ChatType {
  dm
  group
}

enum ScopeType {
  channel
  chat
  session
  ticket
  system
}

enum ActorType {
  user
  agent
  system
}

enum InboxItemType {
  plan
  question
}

enum InboxItemStatus {
  active
  resolved
  dismissed
}

enum ApiTokenProvider {
  anthropic
  openai
  github
  ssh_key
}

enum ParticipantScope {
  channel
  chat
  session
  ticket
  thread
  system
}

enum CloudMachineStatus {
  creating
  started
  stopped
  destroyed
}

enum AgentStatus {
  enabled
  disabled
}

enum AutonomyMode {
  observe
  suggest
  act
}

enum ModelTier {
  tier2
  tier3
}

enum ExecutionDisposition {
  ignore
  suggest
  act
  summarize
  escalate
}

enum ExecutionStatus {
  succeeded
  suggested
  blocked
  dropped
  failed
}

enum EventType {
  message_sent
  message_edited
  message_deleted
  session_started
  session_paused
  session_resumed
  session_terminated
  session_deleted
  session_output
  ticket_created
  ticket_updated
  ticket_commented
  entity_linked
  repo_created
  repo_updated
  channel_created
  member_joined
  member_left
  inbox_item_created
  inbox_item_resolved
  session_pr_opened
  session_pr_merged
  session_pr_closed
  ticket_assigned
  ticket_unassigned
  ticket_linked
  ticket_unlinked
  chat_created
  chat_member_added
  chat_member_removed
  chat_renamed
}

model Organization {
  id       String   @id @default(uuid())
  name     String
  settings Json     @default("{}")

  members  User[]
  repos    Repo[]
  projects Project[]
  channels Channel[]
  sessions Session[]
  tickets  Ticket[]
  events        Event[]
  inboxItems    InboxItem[]
  chats         Chat[]
  messages      Message[]
  participants  Participant[]
  cloudMachines CloudMachine[]
  agentIdentity    AgentIdentity?
  executionLogs    AgentExecutionLog[]
  processedEvents  ProcessedAgentEvent[]
  costTrackers     AgentCostTracker[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentIdentity {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String       @default("Trace AI")
  status         AgentStatus  @default(enabled)
  autonomyMode   AutonomyMode @default(observe)
  soulFile       String       @default("")
  dailyLimitCents Int         @default(1000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentExecutionLog {
  id                    String               @id @default(uuid())
  organizationId        String
  organization          Organization         @relation(fields: [organizationId], references: [id])
  triggerEventId        String
  batchSize             Int                  @default(1)
  agentId               String
  modelTier             ModelTier
  model                 String
  promoted              Boolean              @default(false)
  promotionReason       String?
  inputTokens           Int
  outputTokens          Int
  estimatedCostCents    Float
  disposition           ExecutionDisposition
  confidence            Float
  plannedActions        Json                 @default("[]")
  policyDecision        Json                 @default("{}")
  finalActions          Json                 @default("[]")
  status                ExecutionStatus
  inboxItemId           String?
  latencyMs             Int

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([triggerEventId])
  @@index([organizationId, agentId, status])
}

model ProcessedAgentEvent {
  consumerName   String
  eventId        String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  resultHash     String?

  processedAt DateTime @default(now())

  @@id([consumerName, eventId])
  @@index([organizationId, processedAt])
}

model AgentCostTracker {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  date           String       // YYYY-MM-DD
  totalCostCents Float        @default(0)
  tier2Calls     Int          @default(0)
  tier2CostCents Float        @default(0)
  tier3Calls     Int          @default(0)
  tier3CostCents Float        @default(0)

  updatedAt DateTime @updatedAt

  @@unique([organizationId, date])
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String
  avatarUrl      String?
  githubId       Int?         @unique
  role           UserRole     @default(member)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdSessions   Session[]        @relation("SessionCreator")
  createdTickets    Ticket[]         @relation("TicketCreator")
  ticketAssignments TicketAssignee[] @relation("TicketAssignees")
  createdChats      Chat[]           @relation("ChatCreator")
  chatMemberships   ChatMember[]
  participants      Participant[]
  apiTokens         ApiToken[]
  cloudMachines     CloudMachine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organizationId])
}

model Repo {
  id             String       @id @default(uuid())
  name           String
  remoteUrl      String
  defaultBranch  String       @default("main")
  setupConfig    Json         @default("{}")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  projects Project[]
  sessions Session[]

  webhookId     String?
  webhookSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, remoteUrl])
}

model Project {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])

  channels       ChannelProject[]
  sessions       SessionProject[]
  tickets        TicketProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Channel {
  id             String       @id @default(uuid())
  name           String
  type           ChannelType  @default(default)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  projects ChannelProject[]
  sessions Session[]
  tickets  Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChannelProject {
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([channelId, projectId])
}

model Session {
  id             String       @id @default(uuid())
  name           String
  status         SessionStatus @default(pending)
  tool           CodingTool
  model          String?
  toolChangedAt  DateTime?
  hosting        HostingMode
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("SessionCreator", fields: [createdById], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])
  branch         String?
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])
  parentSessionId String?
  parentSession   Session?  @relation("SessionLineage", fields: [parentSessionId], references: [id])
  childSessions   Session[] @relation("SessionLineage")
  workdir         String?
  toolSessionId   String?
  pendingRun      Json?
  endpoints       Json?
  connection      Json?
  prUrl           String?
  worktreeDeleted Boolean      @default(false)

  projects SessionProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SessionProject {
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([sessionId, projectId])
}

model Ticket {
  id             String       @id @default(uuid())
  title          String
  description    String       @default("")
  status         TicketStatus @default(backlog)
  priority       Priority     @default(medium)
  labels         String[]     @default([])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("TicketCreator", fields: [createdById], references: [id])
  originEventId  String?
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])

  projects  TicketProject[]
  assignees TicketAssignee[]
  links     TicketLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketProject {
  ticketId  String
  ticket    Ticket  @relation(fields: [ticketId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([ticketId, projectId])
}

model TicketAssignee {
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("TicketAssignees", fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([ticketId, userId])
}

model TicketLink {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  @@unique([ticketId, entityType, entityId])
  @@index([entityType, entityId])
}

model ApiToken {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  provider       ApiTokenProvider
  encryptedToken String
  iv             String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
}

model Event {
  id             String       @id @default(uuid())
  scopeType      ScopeType
  scopeId        String
  eventType      EventType
  payload        Json
  actorType      ActorType
  actorId        String
  parentId       String?
  metadata       Json?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  timestamp DateTime @default(now())

  @@index([organizationId, scopeType, scopeId])
  @@index([organizationId, eventType])
  @@index([parentId])
}

model CloudMachine {
  id                String             @id @default(uuid())
  provider          String             // "fly", "aws", etc.
  providerMachineId String
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id])
  status            CloudMachineStatus @default(creating)
  bridgeToken       String             @unique
  runtimeInstanceId String             @unique
  providerMetadata  Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([userId, organizationId])
  @@index([status])
}

model InboxItem {
  id             String          @id @default(uuid())
  itemType       InboxItemType
  status         InboxItemStatus @default(active)
  title          String
  summary        String?
  payload        Json            @default("{}")
  userId         String
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  sourceType     String
  sourceId       String
  createdAt      DateTime        @default(now())
  resolvedAt     DateTime?
  updatedAt      DateTime        @updatedAt

  @@index([userId, status])
  @@index([organizationId, userId])
  @@index([sourceType, sourceId])
}

model Chat {
  id             String       @id @default(uuid())
  type           ChatType
  name           String?
  dmKey          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("ChatCreator", fields: [createdById, organizationId], references: [id, organizationId])

  members ChatMember[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@unique([id, organizationId])
  @@unique([organizationId, dmKey])
}

model Message {
  id              String       @id @default(uuid())
  chatId          String
  organizationId  String
  chat            Chat         @relation(fields: [chatId, organizationId], references: [id, organizationId], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id])
  actorType       ActorType
  actorId         String
  text            String
  html            String?
  mentions        Json?
  parentMessageId String?
  parentMessage   Message?     @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies         Message[]    @relation("MessageThread")
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([chatId, createdAt])
  @@index([parentMessageId, createdAt])
}

model ChatMember {
  chatId          String
  organizationId  String
  chat            Chat     @relation(fields: [chatId, organizationId], references: [id, organizationId], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId, organizationId], references: [id, organizationId], onDelete: Cascade)
  joinedAt        DateTime @default(now())
  leftAt          DateTime?

  @@id([chatId, userId])
  @@index([organizationId])
  @@index([userId])
}

model Participant {
  userId         String
  user           User         @relation(fields: [userId, organizationId], references: [id, organizationId], onDelete: Cascade)
  scopeType      ParticipantScope
  scopeId        String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  subscribedAt   DateTime     @default(now())
  mutedAt        DateTime?

  @@id([userId, scopeType, scopeId])
  @@index([scopeType, scopeId])
  @@index([organizationId, userId])
}
