generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enable pgvector extension for semantic search over memories and summaries.
// Run `CREATE EXTENSION IF NOT EXISTS vector;` on the database before migrating.
// The actual vector columns use Unsupported("vector(1536)") on the models.

enum UserRole {
  admin
  member
  observer
}

enum ChannelType {
  text
  coding
}

enum AgentStatus {
  not_started
  active
  done
  failed
  stopped
}

enum SessionStatus {
  in_progress
  needs_input
  in_review
  merged
}

enum TicketStatus {
  backlog
  todo
  in_progress
  in_review
  done
  cancelled
}

enum Priority {
  urgent
  high
  medium
  low
}

enum HostingMode {
  cloud
  local
}

enum BridgeAccessScopeType {
  all_sessions
  session_group
}

enum BridgeAccessRequestStatus {
  pending
  approved
  denied
}

enum BridgeAccessCapability {
  session
  terminal
}

enum CodingTool {
  claude_code
  codex
  custom
}

enum ChatType {
  dm
  group
}

enum ScopeType {
  channel
  chat
  session
  ticket
  system
}

enum ActorType {
  user
  agent
  system
}

enum InboxItemType {
  plan
  question
}

enum InboxItemStatus {
  active
  resolved
  dismissed
  expired
}

enum ApiTokenProvider {
  anthropic
  openai
  github
  ssh_key
}

enum PushPlatform {
  ios
  android
}

enum ParticipantScope {
  channel
  chat
  session
  ticket
  thread
  system
}

enum CloudMachineStatus {
  creating
  started
  stopped
  destroyed
}

enum AiConversationVisibility {
  PRIVATE
  ORG
}

enum TurnRole {
  USER
  ASSISTANT
}

enum EventType {
  message_sent
  message_edited
  message_deleted
  bridge_access_requested
  bridge_access_request_resolved
  bridge_access_revoked
  bridge_access_updated
  session_started
  session_paused
  session_resumed
  session_terminated
  session_deleted
  session_output
  ticket_created
  ticket_updated
  ticket_commented
  entity_linked
  organization_created
  repo_created
  repo_updated
  channel_created
  channel_updated
  channel_member_added
  channel_member_removed
  channel_group_created
  channel_group_updated
  channel_deleted
  channel_group_deleted
  member_joined
  member_left
  inbox_item_created
  inbox_item_resolved
  session_pr_opened
  session_pr_merged
  session_pr_closed
  session_group_archived
  ticket_assigned
  ticket_unassigned
  ticket_linked
  ticket_unlinked
  chat_created
  chat_member_added
  chat_member_removed
  chat_renamed
  queued_message_added
  queued_message_removed
  queued_messages_cleared
  queued_messages_drained
  agent_environment_created
  agent_environment_updated
  agent_environment_deleted
  session_runtime_start_requested
  session_runtime_provisioning
  session_runtime_connecting
  session_runtime_connected
  session_runtime_start_failed
  session_runtime_start_timed_out
  session_runtime_stopping
  session_runtime_stopped
  session_runtime_deprovision_failed
  session_runtime_disconnected
  session_runtime_reconnected
}

model Organization {
  id       String   @id @default(uuid())
  name     String
  settings Json     @default("{}")

  orgMembers OrgMember[]
  pushTokens PushToken[]
  localMobilePairingTokens LocalMobilePairingToken[]
  localMobileDevices LocalMobileDevice[]
  repos    Repo[]
  projects Project[]
  bridgeRuntimes BridgeRuntime[]
  channelGroups ChannelGroup[]
  channels Channel[]
  sessionGroups SessionGroup[]
  sessions Session[]
  tickets  Ticket[]
  events        Event[]
  inboxItems    InboxItem[]
  agentEnvironments AgentEnvironment[]
  orgSecrets    OrgSecret[]
  cloudMachines CloudMachine[]
  aiConversations  AiConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrgMember {
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           UserRole     @default(member)
  joinedAt       DateTime     @default(now())

  @@id([userId, organizationId])
  @@index([organizationId])
}

model AgentEnvironment {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  adapterType    String
  config         Json         @default("{}")
  enabled        Boolean      @default(true)
  isDefault      Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, adapterType])
}

model OrgSecret {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  encryptedValue String
  iv             String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String
  avatarUrl      String?
  githubId       Int?         @unique

  orgMemberships    OrgMember[]
  localMobilePairingTokens LocalMobilePairingToken[] @relation("LocalMobilePairingTokenOwner")
  localMobileDevices LocalMobileDevice[] @relation("LocalMobileDeviceOwner")
  ownedBridgeRuntimes BridgeRuntime[] @relation("BridgeRuntimeOwner")
  bridgeAccessGrants BridgeAccessGrant[] @relation("BridgeAccessGrantGrantee")
  grantedBridgeAccessGrants BridgeAccessGrant[] @relation("BridgeAccessGrantGrantedBy")
  requestedBridgeAccess BridgeAccessRequest[] @relation("BridgeAccessRequestRequester")
  ownedBridgeAccessRequests BridgeAccessRequest[] @relation("BridgeAccessRequestOwner")
  resolvedBridgeAccessRequests BridgeAccessRequest[] @relation("BridgeAccessRequestResolver")
  createdSessions   Session[]        @relation("SessionCreator")
  createdTickets    Ticket[]         @relation("TicketCreator")
  ticketAssignments TicketAssignee[] @relation("TicketAssignees")
  createdChats      Chat[]           @relation("ChatCreator")
  chatMemberships      ChatMember[]
  channelMemberships   ChannelMember[]
  participants         Participant[]
  apiTokens         ApiToken[]
  pushTokens        PushToken[]
  cloudMachines     CloudMachine[]
  aiConversations   AiConversation[] @relation("AiConversationCreator")
  aiBranches        AiBranch[]       @relation("AiBranchCreator")
  queuedMessages    QueuedMessage[]  @relation("QueuedMessageCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Repo {
  id             String       @id @default(uuid())
  name           String
  remoteUrl      String
  defaultBranch  String       @default("main")
  setupConfig    Json         @default("{}")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  projects Project[]
  sessions Session[]
  sessionGroups SessionGroup[]
  channels Channel[]
  gitCheckpoints GitCheckpoint[]

  webhookId     String?
  webhookSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, remoteUrl])
}

model Project {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])
  soulFile       String       @default("")

  channels       ChannelProject[]
  sessions       SessionProject[]
  tickets        TicketProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChannelGroup {
  id             String       @id @default(uuid())
  name           String
  position       Int          @default(0)
  isCollapsed    Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  channels Channel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, position])
}

model Channel {
  id             String       @id @default(uuid())
  name           String
  type           ChannelType  @default(coding)
  position       Int          @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  groupId        String?
  group          ChannelGroup? @relation(fields: [groupId], references: [id])
  repoId         String?
  repo           Repo?         @relation(fields: [repoId], references: [id])
  baseBranch     String?
  setupScript    String?
  runScripts     Json?          @default("[]")

  projects ChannelProject[]
  sessionGroups SessionGroup[]
  sessions Session[]
  tickets  Ticket[]
  members  ChannelMember[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, position])
}

model ChannelProject {
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([channelId, projectId])
}

model ChannelMember {
  channelId       String
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt        DateTime @default(now())
  leftAt          DateTime?

  @@id([channelId, userId])
  @@index([userId])
  @@index([channelId, leftAt])
}

model SessionGroup {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])
  slug           String?
  branch         String?
  workdir        String?
  connection     Json?
  prUrl          String?
  worktreeDeleted Boolean     @default(false)
  archivedAt      DateTime?
  setupStatus     String      @default("idle")
  setupError      String?

  sessions Session[]
  gitCheckpoints GitCheckpoint[]
  bridgeAccessGrants BridgeAccessGrant[]
  bridgeAccessRequests BridgeAccessRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, updatedAt])
  @@index([channelId, updatedAt])
  @@index([repoId, branch, updatedAt])
}

model Session {
  id             String       @id @default(uuid())
  name           String
  agentStatus    AgentStatus   @default(not_started)
  sessionStatus  SessionStatus @default(in_progress)
  tool           CodingTool
  model          String?
  reasoningEffort String?
  toolChangedAt      DateTime?
  lastUserMessageAt  DateTime?
  lastMessageAt      DateTime?
  hosting        HostingMode
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("SessionCreator", fields: [createdById], references: [id])
  repoId         String?
  repo           Repo?        @relation(fields: [repoId], references: [id])
  branch         String?
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])
  sessionGroupId String?
  sessionGroup   SessionGroup? @relation(fields: [sessionGroupId], references: [id])
  workdir         String?
  toolSessionId   String?
  pendingRun      Json?
  endpoints       Json?
  connection      Json?
  prUrl           String?
  worktreeDeleted Boolean      @default(false)
  readOnlyWorkspace Boolean    @default(false)

  projects        SessionProject[]
  queuedMessages  QueuedMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionGroupId, updatedAt])
  @@index([organizationId, agentStatus])
  @@index([channelId, updatedAt])
}

model QueuedMessage {
  id              String   @id @default(uuid())
  sessionId       String
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  text            String
  imageKeys       String[] @default([])
  interactionMode String?
  position        Int
  createdById     String
  createdBy       User     @relation("QueuedMessageCreator", fields: [createdById], references: [id])
  organizationId  String
  createdAt       DateTime @default(now())

  @@index([sessionId, position])
}

model SessionProject {
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([sessionId, projectId])
}

model Ticket {
  id             String       @id @default(uuid())
  title          String
  description    String       @default("")
  status         TicketStatus @default(backlog)
  priority       Priority     @default(medium)
  labels         String[]     @default([])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User         @relation("TicketCreator", fields: [createdById], references: [id])
  originEventId  String?
  channelId      String?
  channel        Channel?     @relation(fields: [channelId], references: [id])

  projects  TicketProject[]
  assignees TicketAssignee[]
  links     TicketLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status, priority])
}

model TicketProject {
  ticketId  String
  ticket    Ticket  @relation(fields: [ticketId], references: [id])
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  @@id([ticketId, projectId])
}

model TicketAssignee {
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("TicketAssignees", fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([ticketId, userId])
}

model TicketLink {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  @@unique([ticketId, entityType, entityId])
  @@index([entityType, entityId])
}

model ApiToken {
  id             String           @id @default(uuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  provider       ApiTokenProvider
  encryptedToken String
  iv             String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
}

model PushToken {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  token          String
  platform       PushPlatform

  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@unique([userId, token])
  @@index([userId, organizationId])
}

model Event {
  id             String       @id @default(uuid())
  scopeType      ScopeType
  scopeId        String
  eventType      EventType
  payload        Json
  actorType      ActorType
  actorId        String
  parentId       String?
  metadata       Json?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  timestamp DateTime @default(now())
  gitCheckpoints GitCheckpoint[] @relation("GitCheckpointPromptEvent")

  @@index([organizationId, scopeType, scopeId])
  @@index([organizationId, eventType])
  @@index([organizationId, timestamp])
  @@index([parentId])
}

model GitCheckpoint {
  id             String   @id @default(uuid())
  sessionId      String
  sessionGroupId String
  repoId         String
  promptEventId  String
  commitSha      String
  parentShas     String[]
  treeSha        String
  subject        String
  author         String
  committedAt    DateTime
  filesChanged   Int
  createdAt      DateTime @default(now())

  sessionGroup SessionGroup @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  repo         Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  promptEvent  Event @relation("GitCheckpointPromptEvent", fields: [promptEventId], references: [id], onDelete: Restrict)

  @@unique([sessionGroupId, commitSha])
  @@index([sessionId, committedAt])
  @@index([sessionGroupId, committedAt])
  @@index([repoId, committedAt])
  @@index([promptEventId])
}

model CloudMachine {
  id                String             @id @default(uuid())
  provider          String             // "fly", "aws", etc.
  providerMachineId String
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id])
  status            CloudMachineStatus @default(creating)
  bridgeToken       String             @unique
  runtimeInstanceId String             @unique
  providerMetadata  Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([userId, organizationId])
  @@index([status])
}

model BridgeRuntime {
  id             String       @id @default(uuid())
  instanceId     String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerUserId    String
  ownerUser      User         @relation("BridgeRuntimeOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  label          String
  hostingMode    HostingMode
  lastSeenAt     DateTime?
  connectedAt    DateTime?
  disconnectedAt DateTime?
  metadata       Json?

  accessGrants   BridgeAccessGrant[]
  accessRequests BridgeAccessRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([instanceId, organizationId])
  @@index([organizationId, ownerUserId])
  @@index([organizationId, connectedAt])
}

model LocalMobilePairingToken {
  id             String       @id @default(uuid())
  ownerUserId    String
  ownerUser      User         @relation("LocalMobilePairingTokenOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tokenHash      String       @unique
  expiresAt      DateTime
  usedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId, organizationId, usedAt, expiresAt])
}

model LocalMobileDevice {
  id             String       @id @default(uuid())
  ownerUserId    String
  ownerUser      User         @relation("LocalMobileDeviceOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  installId      String
  deviceName     String?
  platform       PushPlatform?
  appVersion     String?
  tokenHash      String       @unique
  lastSeenAt     DateTime?
  revokedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerUserId, organizationId, installId])
  @@index([organizationId, ownerUserId, revokedAt, lastSeenAt])
}

model BridgeAccessGrant {
  id               String                @id @default(uuid())
  bridgeRuntimeId  String
  bridgeRuntime    BridgeRuntime         @relation(fields: [bridgeRuntimeId], references: [id], onDelete: Cascade)
  granteeUserId    String
  granteeUser      User                  @relation("BridgeAccessGrantGrantee", fields: [granteeUserId], references: [id], onDelete: Cascade)
  grantedByUserId  String
  grantedByUser    User                  @relation("BridgeAccessGrantGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Cascade)
  scopeType        BridgeAccessScopeType
  sessionGroupId   String?
  sessionGroup     SessionGroup?         @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  capabilities     BridgeAccessCapability[] @default([])
  expiresAt        DateTime?
  revokedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bridgeRuntimeId, granteeUserId, revokedAt])
  @@index([granteeUserId, revokedAt, expiresAt])
  @@index([sessionGroupId, revokedAt])
}

model BridgeAccessRequest {
  id                 String                    @id @default(uuid())
  bridgeRuntimeId    String
  bridgeRuntime      BridgeRuntime             @relation(fields: [bridgeRuntimeId], references: [id], onDelete: Cascade)
  requesterUserId    String
  requesterUser      User                      @relation("BridgeAccessRequestRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  ownerUserId        String
  ownerUser          User                      @relation("BridgeAccessRequestOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  scopeType          BridgeAccessScopeType
  sessionGroupId     String?
  sessionGroup       SessionGroup?             @relation(fields: [sessionGroupId], references: [id], onDelete: Cascade)
  requestedCapabilities BridgeAccessCapability[] @default([])
  requestedExpiresAt DateTime?
  status             BridgeAccessRequestStatus @default(pending)
  resolvedAt         DateTime?
  resolvedByUserId   String?
  resolvedByUser     User?                     @relation("BridgeAccessRequestResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bridgeRuntimeId, requesterUserId, status])
  @@index([ownerUserId, status, createdAt])
  @@index([sessionGroupId, status])
}

model InboxItem {
  id             String          @id @default(uuid())
  itemType       InboxItemType
  status         InboxItemStatus @default(active)
  title          String
  summary        String?
  payload        Json            @default("{}")
  userId         String
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  sourceType     String
  sourceId       String
  createdAt      DateTime        @default(now())
  resolvedAt     DateTime?
  updatedAt      DateTime        @updatedAt

  @@index([userId, status])
  @@index([organizationId, userId])
  @@index([sourceType, sourceId])
}

model Chat {
  id             String       @id @default(uuid())
  type           ChatType
  name           String?
  dmKey          String?      @unique
  createdById    String
  createdBy      User         @relation("ChatCreator", fields: [createdById], references: [id])

  members ChatMember[]
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id              String       @id @default(uuid())
  chatId          String?
  chat            Chat?        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  channelId       String?
  channel         Channel?     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  actorType       ActorType
  actorId         String
  text            String
  html            String?
  mentions        Json?
  parentMessageId String?
  parentMessage   Message?     @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies         Message[]    @relation("MessageThread")
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([chatId, createdAt])
  @@index([channelId, createdAt])
  @@index([channelId, deletedAt])
  @@index([parentMessageId, createdAt])
}

model ChatMember {
  chatId          String
  chat            Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt        DateTime @default(now())
  leftAt          DateTime?

  @@id([chatId, userId])
  @@index([userId])
}

model Participant {
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopeType    ParticipantScope
  scopeId      String
  subscribedAt DateTime         @default(now())
  mutedAt        DateTime?

  @@id([userId, scopeType, scopeId])
  @@index([scopeType, scopeId])
}

model AiConversation {
  id             String                   @id @default(uuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id])
  createdById    String
  createdBy      User                     @relation("AiConversationCreator", fields: [createdById], references: [id])
  title          String?
  visibility     AiConversationVisibility @default(PRIVATE)
  rootBranchId   String?

  branches AiBranch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, createdById])
  @@index([organizationId, updatedAt])
}

model AiBranch {
  id             String         @id @default(uuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parentBranchId String?
  parentBranch   AiBranch?      @relation("AiBranchTree", fields: [parentBranchId], references: [id])
  childBranches  AiBranch[]     @relation("AiBranchTree")
  forkTurnId     String?
  forkTurn       AiTurn?        @relation("ForkTurn", fields: [forkTurnId], references: [id])
  label          String?
  createdById    String
  createdBy      User           @relation("AiBranchCreator", fields: [createdById], references: [id])

  turns AiTurn[]

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([parentBranchId])
}

model AiTurn {
  id           String   @id @default(uuid())
  branchId     String
  branch       AiBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  role         TurnRole
  content      String
  parentTurnId String?    @unique
  parentTurn   AiTurn?    @relation("AiTurnChain", fields: [parentTurnId], references: [id])
  childTurn    AiTurn?    @relation("AiTurnChain")

  forkedBranches AiBranch[] @relation("ForkTurn")

  createdAt DateTime @default(now())

  @@index([branchId, createdAt])
  @@index([parentTurnId])
}
