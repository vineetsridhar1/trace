{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "declaration": false,
    "declarationMap": false,
    "noEmit": false,
    "noEmitOnError": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "prisma/generated/**/*"],
  "exclude": ["src/**/__tests__/**", "src/**/*.test.ts", "src/**/*.spec.ts"]
}
