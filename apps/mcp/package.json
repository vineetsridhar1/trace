{
  "name": "@trace/mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for Trace — the shared AI coding cockpit. Observe and drive AI coding sessions over Trace's GraphQL API.",
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "bin": {
    "trace-mcp": "dist/index.js"
  },
  "exports": {
