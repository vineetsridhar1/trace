{
  "expo": {
    "name": "Trace",
    "owner": "vineets123",
    "slug": "trace-mobile",
    "version": "0.0.1",
    "scheme": "trace",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "org.gettrace",
      "supportsTablet": false,
      "associatedDomains": ["applinks:gettrace.org"]
    },
    "android": {
      "package": "org.gettrace.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Trace to scan a QR code from your local app."
        }
      ],
      "expo-secure-store",
      "expo-notifications",
      "react-native-bottom-tabs",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Trace to attach images from your photo library."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "fe5684ac-1711-4b45-b3e6-40a9b8d63c16"
      },
      "router": {}
    }
  }
}
