{
  "expo": {
    "name": "Trace",
    "slug": "trace-mobile",
    "version": "0.0.1",
    "scheme": "trace",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "org.gettrace.mobile",
      "supportsTablet": false,
      "associatedDomains": ["applinks:gettrace.org"]
    },
    "android": {
      "package": "org.gettrace.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Trace to scan a QR code from your local app."
        }
      ],
      "expo-secure-store",
      "expo-notifications",
      "react-native-bottom-tabs",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Trace to attach images from your photo library."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
