generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id             String   @id @default(uuid())
  sessionId      String   @unique @map("session_id")
  transcriptPath String?  @map("transcript_path")
  cwd            String?
  permissionMode String?  @map("permission_mode")
  firstSeenAt    DateTime @default(now()) @map("first_seen_at")
  lastSeenAt     DateTime @default(now()) @map("last_seen_at")
  status         String   @default("active")

  events   Event[]
  messages Message[]

  @@map("sessions")
}

model Channel {
  id             String   @id @default(uuid())
  name           String
  baseBranch     String?  @map("base_branch")
  githubUrl      String?  @map("github_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  messages       Message[]
  kanbanColumns  KanbanColumn[]

  @@map("channels")
}

model Message {
  id         String   @id @default(uuid())
  channelId  String   @map("channel_id")
  sessionId  String   @map("session_id")
  preview    String?
  importance String   @default("non-important")
  status     String   @default("pending")
  summary        String?
  branch         String?
  claudeSessionId String?  @map("claude_session_id")
  createdAt      DateTime @default(now()) @map("created_at")

  channel Channel @relation(fields: [channelId], references: [id])
  session Session @relation(fields: [sessionId], references: [sessionId])
  threads Thread[]
  ticket  Ticket?

  @@index([channelId, createdAt])
  @@map("messages")
}

model Thread {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id])
  events  Event[]

  @@map("threads")
}

model Event {
  id                   String   @id @default(uuid())
  sessionId            String   @map("session_id")
  hookEventName        String   @map("hook_event_name")
  timestamp            DateTime @default(now())
  toolName             String?  @map("tool_name")
  toolInput            Json?    @map("tool_input")
  toolResponse         Json?    @map("tool_response")
  toolUseId            String?  @map("tool_use_id")
  stopHookActive       Boolean? @map("stop_hook_active")
  lastAssistantMessage String?  @map("last_assistant_message")
  rawPayload           Json     @map("raw_payload")
  threadId             String   @map("thread_id")
  importance           String   @default("non-important")

  session Session @relation(fields: [sessionId], references: [sessionId])
  thread  Thread  @relation(fields: [threadId], references: [id])

  @@index([sessionId, timestamp])
  @@index([hookEventName])
  @@index([toolName])
  @@index([sessionId, hookEventName])
  @@index([threadId, timestamp])
  @@map("events")
}

model KanbanColumn {
  id        String   @id @default(uuid())
  channelId String   @map("channel_id")
  name      String
  slug      String
  color     String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  channel Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@unique([channelId, slug])
  @@index([channelId, sortOrder])
  @@map("kanban_columns")
}

model Ticket {
  id               String   @id @default(uuid())
  messageId        String   @unique @map("message_id")
  columnId         String   @map("column_id")
  title            String
  description      String?
  solutionApproach String?  @map("solution_approach")
  status           String   @default("open")
  metadata         Json?
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  message Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  column  KanbanColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@index([columnId, sortOrder])
  @@map("tickets")
}
