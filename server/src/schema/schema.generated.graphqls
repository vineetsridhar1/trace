type AiChat {
  channelId: String
  createdAt: DateTime!
  id: ID!
  lastMessage: String
  serverId: String!
  title: String!
  updatedAt: DateTime!
}

type AiChatMessage {
  chatId: String!
  content: String!
  createdAt: DateTime!
  id: ID!
  role: String!
}

type AiChatMessageConnection {
  limit: Int!
  messages: [AiChatMessage!]!
  offset: Int!
  total: Int!
}

type AiChatStreamPayload {
  chatId: String!
  content: String
  delta: String
  error: String
  type: String!
}

type Attachment {
  byteSize: Int!
  contentType: String!
  filename: String!
  id: ID!
  key: String!
  localPath: String!
  url: String!
}

type Channel {
  baseBranch: String
  createdAt: DateTime!
  defaultRepoPath: String
  defaultRunScript: String
  defaultSetupScript: String
  githubUrl: String
  id: ID!
  name: String!
  serverId: String!
  updatedAt: DateTime!
}

type CreateMessagePayload {
  event: Event!
  message: Message!
  thread: Thread!
}

scalar DateTime

type Event {
  hookEventName: String!
  id: ID!
  importance: String!
  lastAssistantMessage: String
  rawPayload: JSON!
  sessionId: String!
  stopHookActive: Boolean
  threadId: String!
  timestamp: DateTime!
  toolInput: JSON
  toolName: String
  toolResponse: JSON
  toolUseId: String
}

type EventConnection {
  events: [Event!]!
  limit: Int!
  offset: Int!
  total: Int!
}

scalar JSON

type KanbanColumn {
  channelId: String!
  color: String
  id: ID!
  name: String!
  slug: String!
  sortOrder: Int!
  tickets: [Ticket!]!
}

type Message {
  branch: String
  channelId: String!
  claudeSessionId: String
  createdAt: DateTime!
  id: ID!
  importance: String!
  preview: String
  session: MessageSession
  sessionId: String!
  status: String!
  summary: String
  threadCount: Int!
}

type MessageConnection {
  limit: Int!
  messages: [Message!]!
  offset: Int!
  total: Int!
}

type MessageDeletedPayload {
  channelId: String!
  messageId: String!
}

type MessageSession {
  cwd: String
  sessionId: String!
  status: String!
}

type Mutation {
  appendPrompt(attachmentIds: [String!], channelId: ID!, createNewThread: Boolean, messageId: ID!, text: String!, threadId: ID): CreateMessagePayload!
  createAiChat(channelId: ID, serverId: ID!, title: String): AiChat!
  createChannel(baseBranch: String, defaultRepoPath: String, defaultRunScript: String, defaultSetupScript: String, githubUrl: String, name: String!, serverId: String): Channel!
  createColumn(channelId: ID!, color: String, name: String!, slug: String!): KanbanColumn!
  createMessage(attachmentIds: [String!], channelId: ID!, text: String!): CreateMessagePayload!
  createServer(avatarUrl: String, name: String!): Server!
  createThread(channelId: ID!, messageId: ID!): Thread!
  deleteAiChat(id: ID!): Boolean!
  deleteColumn(columnId: ID!): Boolean!
  deleteMessage(channelId: ID!, messageId: ID!): Boolean!
  moveTicket(columnId: ID!, sortOrder: Int, ticketId: ID!): Ticket!
  removeTicketDependency(channelId: ID!, dependsOnMessageId: ID!, messageId: ID!): Boolean!
  renameAiChat(id: ID!, title: String!): AiChat!
  sendAiChatMessage(chatId: ID!, content: String!): AiChatMessage!
  setTicketDependencies(channelId: ID!, dependsOnMessageIds: [ID!]!, messageId: ID!, runConfig: JSON!): Message!
  updateChannel(baseBranch: String, defaultRepoPath: String, defaultRunScript: String, defaultSetupScript: String, githubUrl: String, id: ID!, name: String): Channel!
  updateColumn(color: String, columnId: ID!, name: String, sortOrder: Int): KanbanColumn!
  updateMessagePreview(channelId: ID!, messageId: ID!, preview: String!): Message!
  updateMessageStatus(channelId: ID!, messageId: ID!, status: String!): Message!
  uploadAttachment(contentType: String!, data: String!, filename: String!): Attachment!
}

type Query {
  aiChatMessages(chatId: ID!, limit: Int, offset: Int): AiChatMessageConnection!
  aiChats(serverId: ID!): [AiChat!]!
  board(channelId: ID!): [KanbanColumn!]!
  channel(id: ID!): Channel
  channels: [Channel!]!
  event(id: ID!): Event
  messageEvents(after: String, channelId: ID!, limit: Int, messageId: ID!, offset: Int): EventConnection!
  messages(channelId: ID!, limit: Int, offset: Int): MessageConnection!
  servers: [Server!]!
  session(sessionId: String!): Session
  sessionEvents(after: String, hookEventName: String, limit: Int, offset: Int, sessionId: String!, toolName: String): EventConnection!
  sessions(limit: Int, offset: Int, order: String, sort: String, status: String): SessionConnection!
  threadEvents(after: String, channelId: ID!, limit: Int, messageId: ID!, offset: Int, threadId: ID!): EventConnection!
  threads(channelId: ID!, messageId: ID!): [Thread!]!
  ticketDependencies(messageId: ID!): [TicketDependency!]!
}

type Server {
  avatarUrl: String
  channels: [Channel!]!
  createdAt: DateTime!
  id: ID!
  name: String!
  updatedAt: DateTime!
}

type Session {
  cwd: String
  eventCount: Int!
  firstSeenAt: DateTime!
  id: ID!
  lastSeenAt: DateTime!
  permissionMode: String
  sessionId: String!
  status: String!
  toolSummary: JSON
  transcriptPath: String
}

type SessionConnection {
  limit: Int!
  offset: Int!
  sessions: [Session!]!
  total: Int!
}

type Subscription {
  aiChatStream(chatId: ID!): AiChatStreamPayload!
  messageDeleted(channelId: ID!): MessageDeletedPayload!
  messageUpserted(channelId: ID!): Message!
  threadEventCreated(channelId: ID!): ThreadEventPayload!
  threadEventUpdated(channelId: ID!): ThreadEventPayload!
  ticketReadyToRun(channelId: ID!): TicketReadyToRunPayload!
  ticketUpserted(channelId: ID!): TicketUpsertPayload!
}

type Thread {
  createdAt: DateTime!
  eventCount: Int!
  id: ID!
  messageId: String!
}

type ThreadEventPayload {
  channelId: String!
  event: Event!
  messageId: String!
  threadId: String!
}

type Ticket {
  columnId: String!
  createdAt: DateTime!
  description: String
  id: ID!
  message: TicketMessage
  messageId: String!
  metadata: JSON
  solutionApproach: String
  sortOrder: Int!
  status: String!
  title: String!
  updatedAt: DateTime!
}

type TicketAttachment {
  contentType: String!
  filename: String!
  id: ID!
  key: String!
  url: String!
}

type TicketDependency {
  createdAt: DateTime!
  dependsOnMessageId: String!
  dependsOnTicketTitle: String
  id: ID!
  ticketMessageId: String!
}

type TicketMessage {
  attachments: [TicketAttachment!]!
  branch: String
  createdAt: DateTime!
  id: ID!
  status: String!
}

type TicketReadyToRunPayload {
  channelId: String!
  messageId: String!
  runConfig: JSON!
}

type TicketUpsertPayload {
  channelId: String!
  columnSlug: String!
  ticket: Ticket!
}