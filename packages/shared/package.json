{
  "name": "@trace/shared",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./animal-names": {
      "types": "./dist/animal-names.d.ts",
      "import": "./dist/animal-names.js",
      "require": "./dist/cjs/animal-names.js"
    },
    "./git-hooks": {
      "types": "./dist/git-hooks.d.ts",
      "import": "./dist/git-hooks.js",
      "require": "./dist/cjs/git-hooks.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js",
      "require": "./dist/cjs/adapters.js"
    }
  },
  "typesVersions": {
    "*": {
      "animal-names": [
        "dist/animal-names.d.ts"
      ],
      "git-hooks": [
        "dist/git-hooks.d.ts"
      ],
      "adapters": [
        "dist/adapters.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc -b && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "dev": "pnpm build && (tsc -b --watch & tsc -p tsconfig.cjs.json --watch & wait)",
    "lint": "tsc -b"
  },
  "peerDependencies": {
    "node-pty": "^1.1.0"
  },
  "peerDependenciesMeta": {
    "node-pty": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "node-pty": "^1.1.0",
    "typescript": "^5.7.0"
  }
}
