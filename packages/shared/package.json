{
  "name": "@trace/shared",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./adapters": {
      "import": "./dist/adapters.js",
      "require": "./dist/cjs/adapters.js"
    }
  },
  "typesVersions": {
    "*": {
      "adapters": ["dist/adapters.d.ts"]
    }
  },
  "scripts": {
    "build": "tsc -b && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "dev": "pnpm build && (tsc -b --watch & tsc -p tsconfig.cjs.json --watch & wait)",
    "lint": "tsc -b"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
