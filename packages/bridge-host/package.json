{
  "name": "@trace/bridge-host",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./hook-runner": {
      "types": "./dist/hook-runner.d.ts",
      "import": "./dist/hook-runner.js",
      "require": "./dist/cjs/hook-runner.js"
    }
  },
  "scripts": {
    "build": "tsc -b && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "lint": "tsc -b",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@trace/shared": "workspace:*",
    "node-pty": "^1.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
