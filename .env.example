# Server
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tracev2?schema=public"
REDIS_URL="redis://localhost:6379"

# Storage — "local" writes to tmp/uploads/ (good for local dev),
# "s3" uses AWS S3 (production default — server defaults to "s3" if unset).
STORAGE_MODE=local
# STORAGE_PUBLIC_URL=http://localhost:4000   # only needed if overriding the default
# LOCAL_STORAGE_DIR=./tmp/uploads            # only needed if overriding the default
# S3_BUCKET=                                 # required when STORAGE_MODE=s3
# AWS_REGION=                                # required when STORAGE_MODE=s3

# Desktop
TRACE_WEB_URL="http://localhost:3000"
TRACE_AUTH_COOKIE_SAME_SITE="lax"

# Web build
# Optional for local development. Production builds that use AG Grid Enterprise
# should provide this through CI secrets, never in committed files.
VITE_AG_GRID_LICENSE_KEY=""
